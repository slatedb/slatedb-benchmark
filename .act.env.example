AWS_ACCESS_KEY_ID=slatedb
AWS_SECRET_ACCESS_KEY=slatedb-secret
AWS_REGION=us-east-1
AWS_ENDPOINT_URL_S3=http://host.docker.internal:9000
AWS_ALLOW_HTTP=true
AWS_VIRTUAL_HOSTED_STYLE_REQUEST=false
SLATEDB_BENCH_BUCKET=slatedb-benchmarks
SLATEDB_BENCH_PREFIX=benchmark
SLATEDB_BENCH_REGION=local
SLATEDB_BENCH_RUNNER_TYPE=local-act
RUST_LOG=info
