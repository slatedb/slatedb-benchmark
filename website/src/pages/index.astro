---
import { latestStable, loadWorkloadResults, routeHref } from '../lib/results';

const workloads = await loadWorkloadResults();
const latest = latestStable(workloads);
const preferred = latest
  ? workloads.find((route) => route.version === latest.version && route.name === 'balanced') ?? latest
  : undefined;

if (!preferred) throw new Error('website requires at least one workload result');

const redirect = routeHref(preferred);
const canonical = new URL(redirect, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=${redirect}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={canonical} />
    <title>SlateDB Benchmarks</title>
    <script is:inline define:vars={{ redirect }}>
      window.location.replace(redirect);
    </script>
  </head>
  <body></body>
</html>
