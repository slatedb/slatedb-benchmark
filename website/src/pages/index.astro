---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import {
  latestStable,
  loadPreparationResults,
  loadWorkloadResults,
  routeHref,
} from '../lib/results';

const workloads = await loadWorkloadResults();
const latest = latestStable(workloads);
const preferred = latest
  ? workloads.find((route) => route.version === latest.version && route.name === 'balanced') ?? latest
  : latestStable(await loadPreparationResults());
const redirect = preferred ? routeHref(preferred) : undefined;
if (redirect) return Astro.redirect(redirect);
---

<Base title="SlateDB Benchmarks">
  <SiteHeader />
  <main class="empty-state">
    <p class="eyebrow">SlateDB benchmarks</p>
    <h1>No published results yet.</h1>
    <p>Result files checked into <code>results/</code> appear after the next static build.</p>
  </main>
</Base>
