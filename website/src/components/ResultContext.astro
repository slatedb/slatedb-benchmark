---
import {
  compareVersions,
  datasetHref,
  routeHref,
  versionLabel,
  type ResultRoute,
  type SourceIdentity,
} from '../lib/results';

interface Props {
  version: string;
  kind: 'dataset' | 'workload';
  name: string;
  goldenId: string;
  source: SourceIdentity;
  timestamp: string;
  rawResult: string;
  actionsLogUrl?: string;
  routes: ResultRoute<unknown>[];
}

const {
  version,
  kind,
  name,
  goldenId,
  source,
  timestamp,
  rawResult,
  actionsLogUrl,
  routes,
} = Astro.props;
const versions = [...new Set(
  routes
    .filter((route) => route.kind === 'workload' || route.name === 'compaction')
    .map((route) => route.version),
)]
  .sort((left, right) => compareVersions(right, left));
const versionRoutes = routes.filter((route) => route.version === version);
const workloads = versionRoutes
  .filter((route) => route.kind === 'workload')
  .sort((left, right) => left.name.localeCompare(right.name));
const versionOptions = versions.map((candidate) => {
  const candidateRoutes = routes.filter((route) => route.version === candidate);
  const dataset = candidateRoutes.find(
    (route) => route.kind === 'preparation' && route.name === 'compaction',
  );
  const workload = candidateRoutes.find(
    (route) => route.kind === 'workload' && route.name === name,
  ) ?? candidateRoutes.find((route) => route.kind === 'workload');
  return {
    version: candidate,
    label: versionLabel(candidate),
    href: kind === 'dataset' && dataset
      ? datasetHref(candidate)
      : workload ? routeHref(workload) : datasetHref(candidate),
  };
});
const hasDataset = versionRoutes.some(
  (route) => route.kind === 'preparation' && route.name === 'compaction',
);
---

<aside class="result-context" aria-label="Benchmark context">
  <div class="context-block">
    <label class="context-label" for="result-version">Version</label>
    <select class="route-select" id="result-version" data-route-select>
      {versionOptions.map((option) => (
        <option value={option.href} selected={option.version === version}>{option.label}</option>
      ))}
    </select>
  </div>

  <div class="context-block">
    <label class="context-label" for="result-workload">Workloads</label>
    <select class="route-select workload-select" id="result-workload" data-route-select>
      {kind === 'dataset' && <option value="" selected>Choose workload</option>}
      {workloads.map((route) => (
        <option value={routeHref(route)} selected={kind === 'workload' && route.name === name}>
          {route.name}
        </option>
      ))}
    </select>
    <nav class="link-list" aria-label="Workload results">
      {workloads.map((route) => (
        <a class:list={{ current: kind === 'workload' && route.name === name }} href={routeHref(route)}>
          {route.name}
        </a>
      ))}
    </nav>
  </div>

  <dl class="metadata-list">
    <div>
      <dt>Golden data</dt>
      <dd>{hasDataset ? <a href={datasetHref(version)}>{goldenId}</a> : goldenId}</dd>
    </div>
    <div>
      <dt>Recorded</dt>
      <dd>{new Date(timestamp).toLocaleString('en-US', { timeZone: 'UTC', timeZoneName: 'short' })}</dd>
    </div>
  </dl>

  <div class="context-links">
    <a href={rawResult}>Raw result</a>
    {actionsLogUrl && <a href={actionsLogUrl}>Actions log ↗</a>}
    <a href={`https://github.com/slatedb/slatedb/tree/${source.slate_commit}`}>SlateDB source ↗</a>
    <a href={`https://github.com/slatedb/slatedb-benchmark/tree/${source.runner_commit}`}>Runner source ↗</a>
  </div>
</aside>

<script>
  document.querySelectorAll<HTMLSelectElement>('[data-route-select]').forEach((select) => {
    select.addEventListener('change', () => {
      if (select.value) window.location.assign(select.value);
    });
  });
</script>
