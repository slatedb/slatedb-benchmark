---
import type { ResolvedConfiguration } from '../lib/results';

interface Props {
  configuration: ResolvedConfiguration;
}

type Row = { path: string[]; value: string; nonDefault: boolean };

const { configuration } = Astro.props;
const {
  slate_settings: slateSettings,
  slate_default_settings: slateDefaultSettings,
  ...runnerConfiguration
} = configuration;
const isRecord = (value: unknown): value is Record<string, unknown> =>
  typeof value === 'object' && value !== null && !Array.isArray(value);
const label = (value: string) => value
  .replaceAll('_', ' ')
  .replace(/\bwal\b/gi, 'WAL')
  .replace(/\bsst\b/gi, 'SST')
  .replace(/\bl0\b/gi, 'L0');
const formatBytes = (bytes: number) => {
  const units = ['B', 'KiB', 'MiB', 'GiB', 'TiB'];
  let amount = bytes;
  let index = 0;
  while (amount >= 1024 && index < units.length - 1) {
    amount /= 1024;
    index += 1;
  }
  return `${amount.toLocaleString('en-US', { maximumFractionDigits: 2 })} ${units[index]}`;
};
const formatScalar = (value: unknown, path: string[]) => {
  if (typeof value === 'boolean') return value ? 'Yes' : 'No';
  if (typeof value === 'number') {
    const key = path.at(-1) ?? '';
    if (key.endsWith('_bytes')) return formatBytes(value);
    if (key.endsWith('_ms')) return `${value.toLocaleString('en-US')} ms`;
    return value.toLocaleString('en-US', { maximumFractionDigits: 6 });
  }
  return String(value);
};
const equal = (left: unknown, right: unknown) => JSON.stringify(left) === JSON.stringify(right);
const flatten = (
  value: unknown,
  current: string[] = [],
  defaultValue?: unknown,
  compareWithDefault = false,
): Row[] => {
  const row = (formatted: string): Row => ({
    path: current,
    value: formatted,
    nonDefault: compareWithDefault && !equal(value, defaultValue),
  });
  if (value === null || value === undefined) return [row('—')];
  if (Array.isArray(value)) return [row(value.join(', ') || '—')];
  if (isRecord(value)) {
    const entries = Object.entries(value);
    if (entries.length === 0) return [row('Default')];
    return entries.flatMap(([key, nested]) => flatten(
      nested,
      [...current, key],
      isRecord(defaultValue) ? defaultValue[key] : undefined,
      compareWithDefault,
    ));
  }
  return [row(formatScalar(value, current))];
};
const groups: [string, Row[]][] = [
  ['Benchmark configuration', flatten(runnerConfiguration)],
  [
    'SlateDB configuration',
    flatten(slateSettings, [], slateDefaultSettings, slateDefaultSettings !== undefined),
  ],
];
---

{groups.map(([name, rows]) => (
  <section class="metric-section">
    <div class="section-heading">
      <h2>{name}</h2>
    </div>
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th scope="col">Key</th>
            <th scope="col">Value</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class:list={{ 'non-default': row.nonDefault }}>
              <th scope="row">{row.path.map(label).join(' / ')}</th>
              <td><code>{row.value}</code></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
))}

<style>
  tr.non-default :is(th, td) {
    font-weight: 600;
  }
</style>
