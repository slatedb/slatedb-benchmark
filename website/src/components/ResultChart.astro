---
import type { ChartManifest } from '../lib/charts';

interface Props {
  charts: ChartManifest[];
  variant: string;
}

const { charts, variant } = Astro.props;
const initial = charts[0];
---

<section
  class="timeseries-region"
  aria-label="Performance charts"
  data-chart-switcher
  data-chart-variant={variant}
>
  <div class="chart-toolbar">
    <p class="chart-description" id="active-chart-description" data-chart-description>
      {initial.description}
    </p>
    <label class="chart-selector">
      <span>Chart</span>
      <select data-chart-select aria-label="Chart">
        {charts.map((chart, index) => (
          <option
            value={chart.key}
            data-chart-href={chart.href}
            data-chart-description={chart.description}
            selected={index === 0}
          >
            {chart.title}
          </option>
        ))}
      </select>
    </label>
  </div>
  <div class="chart-stage" data-chart-stage aria-busy="false">
    <figure class="time-chart">
      <div class="time-chart-canvas">
        <canvas
          data-time-chart
          aria-label={`${initial.title} for ${variant}`}
          aria-describedby="active-chart-description"
        ></canvas>
        <p class="chart-status" data-chart-status role="status">Loading chart…</p>
      </div>
    </figure>
  </div>
</section>

<script>
  type ChartPayload = {
    key: string;
    title: string;
    description: string;
    unit: string;
    digits: number;
    showPoints?: boolean;
    x: number[][];
    datasets: Array<{
      label: string;
      color: string;
      x: number;
      y: number[];
      dash?: number[];
      width?: number;
    }>;
  };
  type ChartConstructor = typeof import('chart.js/auto').default;

  const payloads = new Map<string, Promise<ChartPayload>>();
  let chartConstructor: Promise<ChartConstructor> | null = null;

  const loadChartConstructor = () => {
    chartConstructor ??= import('chart.js/auto')
      .then((module) => module.default)
      .catch((error) => {
        chartConstructor = null;
        throw error;
      });
    return chartConstructor;
  };

  const loadPayload = (href: string) => {
    const cached = payloads.get(href);
    if (cached) return cached;
    const pending = fetch(href)
      .then((response) => {
        if (!response.ok) throw new Error(`Chart request failed with ${response.status}`);
        return response.json() as Promise<ChartPayload>;
      })
      .catch((error) => {
        payloads.delete(href);
        throw error;
      });
    payloads.set(href, pending);
    return pending;
  };

  document.querySelectorAll<HTMLElement>('[data-chart-switcher]').forEach((switcher) => {
    const select = switcher.querySelector<HTMLSelectElement>('[data-chart-select]');
    const description = switcher.querySelector<HTMLElement>('[data-chart-description]');
    const stage = switcher.querySelector<HTMLElement>('[data-chart-stage]');
    const canvas = switcher.querySelector<HTMLCanvasElement>('[data-time-chart]');
    const status = switcher.querySelector<HTMLElement>('[data-chart-status]');
    const variant = switcher.dataset.chartVariant || 'benchmark';
    let visible = false;
    let requestVersion = 0;
    let activeChart: { destroy: () => void } | null = null;

    const selectedOption = () => select?.selectedOptions[0];
    const renderSelected = async () => {
      const option = selectedOption();
      if (!option || !stage || !canvas || !status) return;
      if (description && option.dataset.chartDescription) {
        description.textContent = option.dataset.chartDescription;
      }
      canvas.setAttribute('aria-label', `${option.textContent || 'Chart'} for ${variant}`);
      if (!visible) return;

      const href = option.dataset.chartHref;
      if (!href) return;
      const currentRequest = ++requestVersion;
      stage.setAttribute('aria-busy', 'true');
      status.textContent = 'Loading chart…';
      status.hidden = false;

      try {
        const [chart, Chart] = await Promise.all([
          loadPayload(href),
          loadChartConstructor(),
        ]);
        if (currentRequest !== requestVersion) return;

        const pointCount = chart.datasets.reduce((count, dataset) => count + dataset.y.length, 0);
        const large = pointCount > 2_000;
        const datasets = chart.datasets.map((dataset) => {
          const x = chart.x[dataset.x];
          if (!x || x.length !== dataset.y.length) {
            throw new Error(`Invalid X axis for ${chart.key}/${dataset.label}`);
          }
          return {
            label: dataset.label,
            data: dataset.y.map((y, index) => ({ x: x[index], y })),
            borderColor: dataset.color,
            backgroundColor: dataset.color,
            borderWidth: dataset.width ?? 1.8,
            borderDash: dataset.dash ?? [],
            pointRadius: chart.showPoints ? 3 : 0,
            pointHoverRadius: chart.showPoints ? 5 : 3,
            tension: large ? 0 : 0.16,
          };
        });

        activeChart?.destroy();
        activeChart = new Chart(canvas, {
          type: 'line',
          data: { datasets },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            parsing: false,
            normalized: true,
            devicePixelRatio: Math.min(window.devicePixelRatio || 1, 2),
            animation: large ? false : { duration: 320, easing: 'easeOutQuart' },
            interaction: { mode: 'index', intersect: false },
            scales: {
              x: {
                type: 'linear',
                grid: { display: false },
                title: { display: true, text: 'Elapsed seconds' },
                ticks: { maxTicksLimit: 8 },
              },
              y: {
                beginAtZero: chart.key === 'payload-throughput',
                title: { display: true, text: chart.unit },
                grid: { color: 'rgba(15,22,32,.07)' },
                ticks: { maxTicksLimit: 6 },
              },
            },
            plugins: {
              decimation: { enabled: false },
              legend: {
                display: chart.datasets.length > 1,
                align: 'end',
                labels: {
                  usePointStyle: true,
                  pointStyle: 'line',
                  boxWidth: 28,
                  pointStyleWidth: 28,
                  generateLabels: (legendChart) =>
                    Chart.defaults.plugins.legend.labels.generateLabels(legendChart).map((label) => {
                      const dataset = legendChart.data.datasets[label.datasetIndex ?? 0] as {
                        borderDash?: number[];
                        borderWidth?: number;
                      };
                      return {
                        ...label,
                        lineDash: Array.isArray(dataset?.borderDash) ? dataset.borderDash : [],
                        lineWidth: typeof dataset?.borderWidth === 'number'
                          ? dataset.borderWidth
                          : label.lineWidth,
                      };
                    }),
                },
              },
              tooltip: {
                callbacks: {
                  title: (items) => `${Number(items[0]?.parsed.x || 0).toFixed(2)} seconds`,
                  label: (context) => `${context.dataset.label}: ${Number(context.parsed.y).toFixed(chart.digits)} ${chart.unit}`,
                },
              },
            },
          },
        });
        stage.setAttribute('aria-busy', 'false');
        status.hidden = true;
      } catch (error) {
        if (currentRequest !== requestVersion) return;
        stage.setAttribute('aria-busy', 'false');
        status.textContent = 'Chart data could not be loaded.';
        status.hidden = false;
        console.error('Unable to render chart', error);
      }
    };

    select?.addEventListener('change', () => void renderSelected());
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        visible = true;
        observer.disconnect();
        void renderSelected();
      }, { rootMargin: '240px 0px' });
      observer.observe(switcher);
    } else {
      visible = true;
      void renderSelected();
    }
  });
</script>
