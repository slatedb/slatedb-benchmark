---
import type { BenchmarkResult, BenchmarkTimeseries, Latency } from '../lib/results';

interface Props {
  result: BenchmarkResult;
  timeseries: BenchmarkTimeseries;
  variant: string;
}

type Point = { x: number | string; y: number };
type ChartDefinition = {
  key: string;
  title: string;
  description: string;
  unit: string;
  digits: number;
  mode: 'time' | 'percentiles';
  datasets: Array<{
    label: string;
    color: string;
    points: Point[];
    dash?: number[];
    width?: number;
  }>;
};

const { result, timeseries, variant } = Astro.props;
const application = timeseries.application_windows;
const atEnd = (window: { start_offset_ns: number; duration_ns: number }) =>
  (window.start_offset_ns + window.duration_ns) / 1e9;
const seconds = (window: { duration_ns: number }) => window.duration_ns / 1e9;
const mibPerSecond = (bytes: number, durationSeconds: number) =>
  bytes / 1_048_576 / Math.max(durationSeconds, Number.EPSILON);
const machineRate = (field: 'network_bytes_sent' | 'network_bytes_received') =>
  timeseries.samples.slice(1).flatMap((sample, index) => {
    const previous = timeseries.samples[index];
    const duration = (sample.offset_ns - previous.offset_ns) / 1e9;
    if (duration <= 0) return [];
    return [{
      x: sample.offset_ns / 1e9,
      y: mibPerSecond(Math.max(0, sample[field] - previous[field]), duration),
    }];
  });
const latencyDatasets = (rows: Array<{ x: number; latency: Latency }>) => [
  { label: 'p50', color: '#8b94a3', value: (latency: Latency) => latency.p50_ns },
  { label: 'p95', color: '#5e6878', value: (latency: Latency) => latency.p95_ns },
  { label: 'p99', color: '#b26844', value: (latency: Latency) => latency.p99_ns },
].map(({ label, color, value }) => ({
  label,
  color,
  points: rows.map(({ x, latency }) => ({ x, y: value(latency) / 1e6 })),
}));
const slateSettings = result.configuration.slate_settings as Record<string, unknown> | undefined;
const awaitsDurability = slateSettings?.await_durable === true;

const latencyRows = application
  .filter((window) => window.return_latency !== null)
  .map((window) => ({ x: atEnd(window), latency: window.return_latency! }));
const latencyChart: ChartDefinition = {
  key: 'return-latency',
  title: 'Return latency over time',
  description: awaitsDurability
    ? 'SlateDB invocation to API return · includes durability'
    : 'SlateDB invocation to API return',
  unit: 'Milliseconds',
  digits: 3,
  mode: 'time',
  datasets: latencyDatasets(latencyRows),
};

const throughputChart: ChartDefinition = {
  key: 'payload-throughput',
  title: 'Payload throughput',
  description: 'Logical application payload and host-wide network traffic',
  unit: 'MiB / second',
  digits: 2,
  mode: 'time',
  datasets: [
    {
      label: 'Application read',
      color: '#3f6f8f',
      width: 2.2,
      points: application.map((window) => ({
        x: atEnd(window),
        y: mibPerSecond(window.read_payload_bytes, seconds(window)),
      })),
    },
    {
      label: 'Application write',
      color: '#b26844',
      width: 2.2,
      points: application.map((window) => ({
        x: atEnd(window),
        y: mibPerSecond(window.write_payload_bytes, seconds(window)),
      })),
    },
    {
      label: 'Machine download',
      color: '#3f6f8f',
      dash: [7, 5],
      points: machineRate('network_bytes_received'),
    },
    {
      label: 'Machine upload',
      color: '#b26844',
      dash: [7, 5],
      points: machineRate('network_bytes_sent'),
    },
  ],
};

const wholeRunLatency = result.application.return_latency;
const tailLatencyChart: ChartDefinition = {
  key: 'tail-latency',
  title: 'Tail latency',
  description: awaitsDurability
    ? 'Whole-run return latency percentiles · includes durability'
    : 'Whole-run return latency percentiles',
  unit: 'ms',
  digits: 3,
  mode: 'percentiles',
  datasets: [{
    label: 'Return latency',
    color: '#b26844',
    points: [
      { x: 'p50', y: wholeRunLatency.p50_ns / 1e6 },
      { x: 'p95', y: wholeRunLatency.p95_ns / 1e6 },
      { x: 'p99', y: wholeRunLatency.p99_ns / 1e6 },
      { x: 'p99.9', y: wholeRunLatency.p999_ns / 1e6 },
    ],
  }],
};

const durabilityRows = (timeseries.durability_windows || [])
  .filter((window) => window.durability_lag !== null)
  .map((window) => ({ x: atEnd(window), latency: window.durability_lag! }));
const durabilityChart: ChartDefinition | null = durabilityRows.length > 0 ? {
  key: 'durability-lag',
  title: 'Durability lag over time',
  description: 'API return to durable frontier coverage',
  unit: 'Milliseconds',
  digits: 3,
  mode: 'time',
  datasets: latencyDatasets(durabilityRows),
} : null;

const charts = [throughputChart, latencyChart, tailLatencyChart, durabilityChart]
  .filter((chart): chart is ChartDefinition => chart !== null);
---

<section class="timeseries-region" aria-label="Performance charts" data-chart-switcher>
  <div class="chart-toolbar">
    <p class="chart-description" id="active-chart-description" data-chart-description>{charts[0].description}</p>
    <label class="chart-selector">
      <span>Chart</span>
      <select data-chart-select aria-label="Chart">
        {charts.map((chart, index) => (
          <option value={chart.key} selected={index === 0}>{chart.title}</option>
        ))}
      </select>
    </label>
  </div>
  <div class="chart-stage">
    {charts.map((chart, index) => (
      <figure
        class="time-chart"
        id={`${chart.key}-panel`}
        data-chart-panel={chart.key}
        data-chart-description={chart.description}
        hidden={index !== 0}
      >
        <div class="time-chart-canvas">
          <canvas
            data-time-chart={JSON.stringify(chart)}
            aria-label={`${chart.title} for ${variant}`}
            aria-describedby="active-chart-description"
          ></canvas>
        </div>
      </figure>
    ))}
  </div>
</section>

<script>
  import Chart from 'chart.js/auto';

  const renderChart = (canvas: HTMLCanvasElement) => {
    const existing = Chart.getChart(canvas);
    if (existing) {
      existing.resize();
      return;
    }
    const chart = JSON.parse(canvas.dataset.timeChart || '{}');
    const percentiles = chart.mode === 'percentiles';
    new Chart(canvas, {
      type: 'line',
      data: {
        labels: percentiles ? chart.datasets[0]?.points.map((point: { x: string }) => point.x) : undefined,
        datasets: chart.datasets.map((dataset: { label: string; color: string; points: Array<{ x: number | string; y: number }>; dash?: number[]; width?: number }) => ({
          label: dataset.label,
          data: percentiles ? dataset.points.map((point) => point.y) : dataset.points,
          borderColor: dataset.color,
          backgroundColor: dataset.color,
          borderWidth: dataset.width ?? 1.8,
          borderDash: dataset.dash ?? [],
          pointRadius: percentiles ? 3 : 0,
          pointHoverRadius: percentiles ? 5 : 3,
          tension: 0.16,
        })),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 320, easing: 'easeOutQuart' },
        interaction: { mode: 'index', intersect: false },
        scales: {
          x: {
            type: percentiles ? 'category' : 'linear',
            grid: { display: false },
            title: { display: true, text: percentiles ? 'Percentile' : 'Elapsed seconds' },
            ticks: { maxTicksLimit: 8 },
          },
          y: {
            beginAtZero: chart.key === 'payload-throughput',
            title: { display: true, text: chart.unit },
            grid: { color: 'rgba(15,22,32,.07)' },
            ticks: { maxTicksLimit: 6 },
          },
        },
        plugins: {
          legend: {
            display: chart.datasets.length > 1,
            align: 'end',
            labels: { usePointStyle: true, pointStyle: 'line', boxWidth: 18 },
          },
          tooltip: {
            callbacks: {
              title: (items) => percentiles
                ? String(items[0]?.label || '')
                : `${Number(items[0]?.parsed.x || 0).toFixed(2)} seconds`,
              label: (context) => `${context.dataset.label}: ${Number(context.parsed.y).toFixed(chart.digits)} ${chart.unit}`,
            },
          },
        },
      },
    });
  };

  document.querySelectorAll<HTMLElement>('[data-chart-switcher]').forEach((switcher) => {
    const select = switcher.querySelector<HTMLSelectElement>('[data-chart-select]');
    const description = switcher.querySelector<HTMLElement>('[data-chart-description]');
    const panels = [...switcher.querySelectorAll<HTMLElement>('[data-chart-panel]')];
    const activate = (key: string) => {
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.chartPanel !== key;
      });
      const panel = panels.find((candidate) => !candidate.hidden);
      if (description && panel?.dataset.chartDescription) description.textContent = panel.dataset.chartDescription;
      const canvas = panel?.querySelector<HTMLCanvasElement>('[data-time-chart]');
      if (canvas) requestAnimationFrame(() => renderChart(canvas));
    };

    select?.addEventListener('change', () => activate(select.value));
    if (select) activate(select.value);
  });
</script>
