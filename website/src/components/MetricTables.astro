---
import MetricTable from './MetricTable.astro';
import type {
  DistributionSummary,
  LatencySummary,
  RateSummary,
  RecordedMetrics,
  ThroughputSummary,
} from '../lib/results';

interface Props {
  result: RecordedMetrics;
  showEmptyApplication?: boolean;
  showDescriptions?: boolean;
  chartSeriesUrl?: string;
  clientMeasurementNs?: number;
}

const {
  result,
  showEmptyApplication = true,
  showDescriptions = false,
  chartSeriesUrl,
  clientMeasurementNs,
} = Astro.props;
const statisticColumns = ['avg', 'p50', 'p95', 'p99', 'p99.9', 'min', 'max'];
const rateColumns = ['total', 'avg/s', 'p50/s', 'p95/s', 'p99/s', 'p99.9/s', 'min/s', 'max/s'];
const throughputColumns = ['total GiB', 'avg MiB/s', 'p50', 'p95', 'p99', 'p99.9', 'min', 'max'];
const number = new Intl.NumberFormat('en-US', { maximumFractionDigits: 2 });
const compact = new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 2 });
const apiOrder = ['get', 'put', 'delete', 'scan', 'write', 'flush', 'transaction.get', 'transaction.put', 'transaction.commit', 'durable'];
const objectStoreOrder = ['GET', 'PUT', 'HEAD', 'DELETE', 'POST', 'OTHER'];
const ordered = <T,>(values: Record<string, T>, order = apiOrder) => Object.entries(values).sort(([left], [right]) => {
  const leftIndex = order.indexOf(left);
  const rightIndex = order.indexOf(right);
  if (leftIndex === -1 && rightIndex === -1) return left.localeCompare(right);
  if (leftIndex === -1) return 1;
  if (rightIndex === -1) return -1;
  return leftIndex - rightIndex;
});
const rateValues = (value: RateSummary) => [
  compact.format(value.total),
  compact.format(value.avg_per_second),
  compact.format(value.p50_per_second),
  compact.format(value.p95_per_second),
  compact.format(value.p99_per_second),
  compact.format(value.p999_per_second),
  compact.format(value.min_per_second),
  compact.format(value.max_per_second),
];
const throughputValues = (value: ThroughputSummary) => {
  const mib = (bytes: number) => number.format(bytes / 1024 / 1024);
  return [
    number.format(value.total_bytes / 1024 / 1024 / 1024),
    mib(value.avg_bytes_per_second),
    mib(value.p50_bytes_per_second),
    mib(value.p95_bytes_per_second),
    mib(value.p99_bytes_per_second),
    mib(value.p999_bytes_per_second),
    mib(value.min_bytes_per_second),
    mib(value.max_bytes_per_second),
  ];
};
const latencyValues = (value: LatencySummary) => {
  const ms = (nanoseconds: number) => number.format(nanoseconds / 1_000_000);
  return [ms(value.avg_ns), ms(value.p50_ns), ms(value.p95_ns), ms(value.p99_ns), ms(value.p999_ns), ms(value.min_ns), ms(value.max_ns)];
};
const distributionValues = (value: DistributionSummary, divisor = 1) => [
  number.format(value.avg / divisor),
  number.format(value.p50 / divisor),
  number.format(value.p95 / divisor),
  number.format(value.p99 / divisor),
  number.format(value.p999 / divisor),
  number.format(value.min / divisor),
  number.format(value.max / divisor),
];

const timeChart = (source: string, key: string | undefined, unit: string, average: number, divisor = 1) =>
  chartSeriesUrl ? { kind: 'time' as const, source, key, unit, average, divisor } : undefined;
const latencyChart = (key: string) => chartSeriesUrl
  ? { kind: 'latency' as const, source: 'application.latency_ns', key, unit: 'ms', divisor: 1_000_000 }
  : undefined;
const applicationOperations = ordered(result.application.operations).map(([label, value]) => ({
  label,
  values: rateValues(value),
  chart: timeChart('application.operations_per_second', label, 'calls/s', value.avg_per_second),
}));
const applicationThroughput = ordered(result.application.throughput).map(([label, value]) => ({
  label,
  values: throughputValues(value),
  chart: timeChart('application.bytes_per_second', label, 'MiB/s', value.avg_bytes_per_second, 1024 ** 2),
}));
const applicationLatency = ordered(result.application.latency).map(([label, value]) => ({
  label,
  values: latencyValues(value),
  chart: latencyChart(label),
}));
const objectRequests = ordered(result.object_store.requests, objectStoreOrder).map(([label, value]) => ({
  label,
  values: rateValues(value),
  chart: timeChart('object_store.requests_per_second', label, 'requests/s', value.avg_per_second),
}));
const objectThroughput = ordered(result.object_store.throughput, objectStoreOrder).map(([label, value]) => ({
  label,
  values: throughputValues(value),
  chart: timeChart('object_store.bytes_per_second', label, 'MiB/s', value.avg_bytes_per_second, 1024 ** 2),
}));
const process = [
  { label: 'CPU utilization (cores)', values: distributionValues(result.process.cpu_cores), chart: timeChart('process.cpu_cores', undefined, 'cores', result.process.cpu_cores.avg) },
  { label: 'RSS (GiB)', values: distributionValues(result.process.rss_bytes, 1024 ** 3), chart: timeChart('process.rss_bytes', undefined, 'GiB', result.process.rss_bytes.avg, 1024 ** 3) },
];
const machine = [
  { label: 'CPU (%)', values: distributionValues(result.machine.cpu_percent), chart: timeChart('machine.cpu_percent', undefined, '%', result.machine.cpu_percent.avg) },
  { label: 'RSS (GiB)', values: distributionValues(result.machine.rss_bytes, 1024 ** 3), chart: timeChart('machine.rss_bytes', undefined, 'GiB', result.machine.rss_bytes.avg, 1024 ** 3) },
  { label: 'Network receive (MiB/s)', values: distributionValues(result.machine.network_receive_bytes_per_second, 1024 ** 2), chart: timeChart('machine.network_receive_bytes_per_second', undefined, 'MiB/s', result.machine.network_receive_bytes_per_second.avg, 1024 ** 2) },
  { label: 'Network send (MiB/s)', values: distributionValues(result.machine.network_send_bytes_per_second, 1024 ** 2), chart: timeChart('machine.network_send_bytes_per_second', undefined, 'MiB/s', result.machine.network_send_bytes_per_second.avg, 1024 ** 2) },
  { label: 'Disk read (MiB/s)', values: distributionValues(result.machine.disk_read_bytes_per_second, 1024 ** 2), chart: timeChart('machine.disk_read_bytes_per_second', undefined, 'MiB/s', result.machine.disk_read_bytes_per_second.avg, 1024 ** 2) },
  { label: 'Disk write (MiB/s)', values: distributionValues(result.machine.disk_write_bytes_per_second, 1024 ** 2), chart: timeChart('machine.disk_write_bytes_per_second', undefined, 'MiB/s', result.machine.disk_write_bytes_per_second.avg, 1024 ** 2) },
  { label: 'Disk read ops/s', values: distributionValues(result.machine.disk_read_operations_per_second), chart: timeChart('machine.disk_read_operations_per_second', undefined, 'operations/s', result.machine.disk_read_operations_per_second.avg) },
  { label: 'Disk write ops/s', values: distributionValues(result.machine.disk_write_operations_per_second), chart: timeChart('machine.disk_write_operations_per_second', undefined, 'operations/s', result.machine.disk_write_operations_per_second.avg) },
];
---

<div
  data-metric-charts={chartSeriesUrl ? '' : undefined}
  data-series-url={chartSeriesUrl}
  data-client-measurement-ns={clientMeasurementNs}
>
  {(showEmptyApplication || applicationOperations.length > 0) && <MetricTable idPrefix="application-operations" title="Application operations" description={showDescriptions ? "Completed SlateDB API calls, reported as totals and per-second rate distributions." : undefined} firstColumn="API" columns={rateColumns} rows={applicationOperations} />}
  {(showEmptyApplication || applicationThroughput.length > 0) && <MetricTable idPrefix="application-throughput" title="Application throughput" description={showDescriptions ? "Logical key and value bytes passed to or returned from each SlateDB API." : undefined} firstColumn="API" columns={throughputColumns} rows={applicationThroughput} />}
  {(showEmptyApplication || applicationLatency.length > 0) && <MetricTable idPrefix="application-latency" title="Application latency (ms)" description={showDescriptions ? "SlateDB API latency, plus write durability latency measured against the durable frontier." : undefined} firstColumn="API" columns={statisticColumns} rows={applicationLatency} />}
  <MetricTable idPrefix="object-requests" title="Object-store requests" description={showDescriptions ? "Physical object-store HTTP requests, including retries, reported as totals and per-second rate distributions." : undefined} firstColumn="Method" columns={rateColumns} rows={objectRequests} />
  <MetricTable idPrefix="object-throughput" title="Object-store throughput" description={showDescriptions ? "Physical HTTP request and response body bytes transferred to and from object storage." : undefined} firstColumn="Method" columns={throughputColumns} rows={objectThroughput} />
  <MetricTable idPrefix="process" title="Process statistics" description={showDescriptions ? "CPU and resident memory used by the benchmark process, including SlateDB and its embedded compactor." : undefined} firstColumn="Metric" columns={statisticColumns} rows={process} codeLabels={false} />
  <MetricTable idPrefix="machine" title="Machine statistics" description={showDescriptions ? "Host-wide CPU, network, and disk activity, with benchmark-process RSS included for context." : undefined} firstColumn="Metric" columns={statisticColumns} rows={machine} codeLabels={false} />
</div>

<script>
  import { initializeMetricCharts } from '../scripts/metric-charts';

  initializeMetricCharts();
</script>
