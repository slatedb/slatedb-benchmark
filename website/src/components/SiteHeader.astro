---
interface Props {
  scaled?: boolean;
}

const { scaled = false } = Astro.props;
---

<header class="site-header">
  <a class="wordmark" href="https://slatedb.io" aria-label="SlateDB home">
    <img src="/logo-full.svg" alt="SlateDB" />
  </a>
  <a class="site-name" href="/">Benchmarks</a>
  {scaled && <span class="data-badge">Scaled data</span>}
</header>
