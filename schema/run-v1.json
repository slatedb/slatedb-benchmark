{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benchmark.slatedb.io/schema/run-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "started_at", "finished_at", "mode", "slate_version", "slate_commit", "runner_version", "runner_commit", "lockfile_sha256", "resolved_configuration", "object_store_baselines", "results"],
  "properties": {
    "schema_version": { "const": 1 }, "status": { "const": "ok" },
    "started_at": { "type": "string", "format": "date-time" }, "finished_at": { "type": "string", "format": "date-time" },
    "mode": { "enum": ["published", "smoke"] }, "slate_version": { "type": "string" }, "slate_commit": { "type": "string" },
    "runner_version": { "type": "string" }, "runner_commit": { "type": "string" }, "lockfile_sha256": { "type": "string" },
    "resolved_configuration": { "type": "object" },
    "object_store_baselines": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "object" }
    },
    "results": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  }
}
