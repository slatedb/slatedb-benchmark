{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benchmark.slatedb.io/schema/histograms.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["encoding", "significant_digits", "histograms"],
  "properties": {
    "encoding": { "const": "hdrhistogram-v2-deflate-base64" },
    "significant_digits": { "const": 3 },
    "histograms": {
      "type": "object",
      "additionalProperties": {
        "type": "object", "additionalProperties": false,
        "required": ["unit", "count", "min", "max", "data"],
        "properties": {
          "unit": { "const": "microseconds" }, "count": { "type": "integer", "minimum": 0 },
          "min": { "type": "integer", "minimum": 0 }, "max": { "type": "integer", "minimum": 0 },
          "data": { "type": "string", "contentEncoding": "base64" }
        }
      }
    }
  }
}
