{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benchmark.slatedb.io/schema/result.json",
  "title": "SlateDB benchmark task result",
  "oneOf": [
    { "$ref": "#/$defs/preparationResult" },
    { "$ref": "#/$defs/workloadResult" }
  ],
  "$defs": {
    "task": {
      "enum": [
        "bulk-load",
        "full-compaction",
        "idle",
        "point-read-uniform",
        "point-read-skewed",
        "point-read-missing",
        "read-heavy",
        "balanced",
        "update-heavy",
        "range-scan",
        "sustained-ingest",
        "transaction-contention"
      ]
    },
    "workload": {
      "enum": [
        "idle",
        "point-read-uniform",
        "point-read-skewed",
        "point-read-missing",
        "read-heavy",
        "balanced",
        "update-heavy",
        "range-scan",
        "sustained-ingest",
        "transaction-contention"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slate_version",
        "slate_commit",
        "runner_version",
        "runner_commit",
        "lockfile_sha256"
      ],
      "properties": {
        "slate_version": { "type": "string", "minLength": 1 },
        "slate_commit": { "type": "string", "minLength": 1 },
        "runner_version": { "type": "string", "minLength": 1 },
        "runner_commit": { "type": "string", "minLength": 1 },
        "lockfile_sha256": { "type": "string", "minLength": 1 }
      }
    },
    "datasetConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_count",
        "key_bytes",
        "value_bytes",
        "value_compression_ratio"
      ],
      "properties": {
        "record_count": { "type": "integer", "minimum": 1 },
        "key_bytes": { "type": "integer", "minimum": 1 },
        "value_bytes": { "type": "integer", "minimum": 1 },
        "value_compression_ratio": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    },
    "cacheConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["block_bytes", "metadata_bytes", "object_store_bytes"],
      "properties": {
        "block_bytes": { "type": "integer", "minimum": 1 },
        "metadata_bytes": { "type": "integer", "minimum": 1 },
        "object_store_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "taskConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task",
        "clients",
        "warmup_ms",
        "measurement_ms",
        "initial_state",
        "key_selection",
        "operation_mix",
        "scan_limit",
        "transaction_hot_keys",
        "transaction_reads",
        "transaction_updates"
      ],
      "properties": {
        "task": { "$ref": "#/$defs/task" },
        "clients": { "type": "integer", "minimum": 0 },
        "warmup_ms": { "type": "integer", "minimum": 0 },
        "measurement_ms": { "type": "integer", "minimum": 0 },
        "initial_state": { "type": "string", "minLength": 1 },
        "key_selection": { "type": "string", "minLength": 1 },
        "operation_mix": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "scan_limit": { "type": ["integer", "null"], "minimum": 1 },
        "transaction_hot_keys": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "transaction_reads": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "transaction_updates": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scale",
        "dataset",
        "caches",
        "task",
        "slate_settings",
        "build_profile",
        "enabled_features"
      ],
      "properties": {
        "scale": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "dataset": { "$ref": "#/$defs/datasetConfiguration" },
        "caches": { "$ref": "#/$defs/cacheConfiguration" },
        "task": { "$ref": "#/$defs/taskConfiguration" },
        "slate_settings": { "type": "object" },
        "build_profile": { "enum": ["debug", "release"] },
        "enabled_features": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "database_path",
        "checkpoint_id",
        "manifest_id",
        "lsm_digest_sha256",
        "live_sst_bytes"
      ],
      "properties": {
        "database_path": { "type": "string", "minLength": 1 },
        "checkpoint_id": { "type": "string", "minLength": 1 },
        "manifest_id": { "type": "integer", "minimum": 0 },
        "lsm_digest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "live_sst_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "datasetMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_count",
        "key_bytes",
        "value_bytes",
        "logical_bytes",
        "live_sst_bytes"
      ],
      "properties": {
        "record_count": { "type": "integer", "minimum": 1 },
        "key_bytes": { "type": "integer", "minimum": 1 },
        "value_bytes": { "type": "integer", "minimum": 1 },
        "logical_bytes": { "type": "integer", "minimum": 1 },
        "live_sst_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "preparationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "task",
        "golden_id",
        "timestamp",
        "source",
        "configuration",
        "source_checkpoint",
        "checkpoint",
        "dataset"
      ],
      "properties": {
        "status": { "const": "ok" },
        "task": { "enum": ["bulk-load", "full-compaction"] },
        "golden_id": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "source": { "$ref": "#/$defs/source" },
        "configuration": { "$ref": "#/$defs/configuration" },
        "source_checkpoint": {
          "oneOf": [
            { "$ref": "#/$defs/checkpoint" },
            { "type": "null" }
          ]
        },
        "checkpoint": { "$ref": "#/$defs/checkpoint" },
        "dataset": { "$ref": "#/$defs/datasetMetadata" }
      }
    },
    "initialState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "checkpoint_id",
        "manifest_id",
        "lsm_digest_sha256"
      ],
      "properties": {
        "kind": { "enum": ["golden", "empty"] },
        "checkpoint_id": { "type": ["string", "null"] },
        "manifest_id": { "type": ["integer", "null"], "minimum": 0 },
        "lsm_digest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "rateSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "avg_per_second",
        "p50_per_second",
        "p95_per_second",
        "p99_per_second",
        "p999_per_second",
        "min_per_second",
        "max_per_second"
      ],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "avg_per_second": { "type": "number", "minimum": 0 },
        "p50_per_second": { "type": "number", "minimum": 0 },
        "p95_per_second": { "type": "number", "minimum": 0 },
        "p99_per_second": { "type": "number", "minimum": 0 },
        "p999_per_second": { "type": "number", "minimum": 0 },
        "min_per_second": { "type": "number", "minimum": 0 },
        "max_per_second": { "type": "number", "minimum": 0 }
      }
    },
    "throughputSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_bytes",
        "avg_bytes_per_second",
        "p50_bytes_per_second",
        "p95_bytes_per_second",
        "p99_bytes_per_second",
        "p999_bytes_per_second",
        "min_bytes_per_second",
        "max_bytes_per_second"
      ],
      "properties": {
        "total_bytes": { "type": "integer", "minimum": 1 },
        "avg_bytes_per_second": { "type": "number", "minimum": 0 },
        "p50_bytes_per_second": { "type": "number", "minimum": 0 },
        "p95_bytes_per_second": { "type": "number", "minimum": 0 },
        "p99_bytes_per_second": { "type": "number", "minimum": 0 },
        "p999_bytes_per_second": { "type": "number", "minimum": 0 },
        "min_bytes_per_second": { "type": "number", "minimum": 0 },
        "max_bytes_per_second": { "type": "number", "minimum": 0 }
      }
    },
    "latencySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count",
        "avg_ns",
        "p50_ns",
        "p95_ns",
        "p99_ns",
        "p999_ns",
        "min_ns",
        "max_ns"
      ],
      "properties": {
        "count": { "type": "integer", "minimum": 1 },
        "avg_ns": { "type": "number", "minimum": 0 },
        "p50_ns": { "type": "integer", "minimum": 0 },
        "p95_ns": { "type": "integer", "minimum": 0 },
        "p99_ns": { "type": "integer", "minimum": 0 },
        "p999_ns": { "type": "integer", "minimum": 0 },
        "min_ns": { "type": "integer", "minimum": 0 },
        "max_ns": { "type": "integer", "minimum": 0 }
      }
    },
    "distributionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["avg", "p50", "p95", "p99", "p999", "min", "max"],
      "properties": {
        "avg": { "type": "number", "minimum": 0 },
        "p50": { "type": "number", "minimum": 0 },
        "p95": { "type": "number", "minimum": 0 },
        "p99": { "type": "number", "minimum": 0 },
        "p999": { "type": "number", "minimum": 0 },
        "min": { "type": "number", "minimum": 0 },
        "max": { "type": "number", "minimum": 0 }
      }
    },
    "applicationMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operations", "throughput", "latency"],
      "properties": {
        "operations": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/rateSummary" }
        },
        "throughput": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/throughputSummary" }
        },
        "latency": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/latencySummary" }
        }
      }
    },
    "objectStoreMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "throughput"],
      "properties": {
        "requests": {
          "type": "object",
          "propertyNames": {
            "enum": ["GET", "PUT", "HEAD", "DELETE", "POST", "OTHER"]
          },
          "additionalProperties": { "$ref": "#/$defs/rateSummary" }
        },
        "throughput": {
          "type": "object",
          "propertyNames": {
            "enum": ["GET", "PUT", "HEAD", "DELETE", "POST", "OTHER"]
          },
          "additionalProperties": { "$ref": "#/$defs/throughputSummary" }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runner_type",
        "hostname",
        "cpu_model",
        "cpu_cores",
        "ram_bytes",
        "local_disk",
        "os",
        "kernel",
        "object_store",
        "endpoint",
        "region"
      ],
      "properties": {
        "runner_type": { "type": "string" },
        "hostname": { "type": "string" },
        "cpu_model": { "type": "string" },
        "cpu_cores": { "type": "integer", "minimum": 1 },
        "ram_bytes": { "type": "integer", "minimum": 1 },
        "local_disk": { "type": "string" },
        "os": { "type": "string" },
        "kernel": { "type": "string" },
        "object_store": { "type": "string" },
        "endpoint": { "type": "string" },
        "region": { "type": "string" }
      }
    },
    "processStatistics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cpu_cores", "rss_bytes"],
      "properties": {
        "cpu_cores": { "$ref": "#/$defs/distributionSummary" },
        "rss_bytes": { "$ref": "#/$defs/distributionSummary" }
      }
    },
    "machineStatistics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu_percent",
        "rss_bytes",
        "network_receive_bytes_per_second",
        "network_send_bytes_per_second",
        "disk_read_bytes_per_second",
        "disk_write_bytes_per_second",
        "disk_read_operations_per_second",
        "disk_write_operations_per_second"
      ],
      "properties": {
        "cpu_percent": { "$ref": "#/$defs/distributionSummary" },
        "rss_bytes": { "$ref": "#/$defs/distributionSummary" },
        "network_receive_bytes_per_second": {
          "$ref": "#/$defs/distributionSummary"
        },
        "network_send_bytes_per_second": {
          "$ref": "#/$defs/distributionSummary"
        },
        "disk_read_bytes_per_second": {
          "$ref": "#/$defs/distributionSummary"
        },
        "disk_write_bytes_per_second": {
          "$ref": "#/$defs/distributionSummary"
        },
        "disk_read_operations_per_second": {
          "$ref": "#/$defs/distributionSummary"
        },
        "disk_write_operations_per_second": {
          "$ref": "#/$defs/distributionSummary"
        }
      }
    },
    "workloadResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "task",
        "golden_id",
        "session",
        "timestamp",
        "source",
        "environment",
        "configuration",
        "initial_state",
        "client_measurement_ns",
        "durability_drain_ns",
        "recorded_interval_ns",
        "application",
        "object_store",
        "process",
        "machine"
      ],
      "properties": {
        "status": { "const": "ok" },
        "task": { "$ref": "#/$defs/workload" },
        "golden_id": { "type": "string", "minLength": 1 },
        "session": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string", "format": "date-time" },
        "source": { "$ref": "#/$defs/source" },
        "environment": { "$ref": "#/$defs/environment" },
        "configuration": { "$ref": "#/$defs/configuration" },
        "initial_state": { "$ref": "#/$defs/initialState" },
        "client_measurement_ns": { "type": "integer", "minimum": 0 },
        "durability_drain_ns": { "type": "integer", "minimum": 0 },
        "recorded_interval_ns": { "type": "integer", "minimum": 1 },
        "application": { "$ref": "#/$defs/applicationMetrics" },
        "object_store": { "$ref": "#/$defs/objectStoreMetrics" },
        "process": { "$ref": "#/$defs/processStatistics" },
        "machine": { "$ref": "#/$defs/machineStatistics" }
      }
    }
  }
}
