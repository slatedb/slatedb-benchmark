{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benchmark.slatedb.io/schema/timeseries.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["interval_ns", "samples", "application_windows", "durability_windows", "slatedb_metrics"],
  "properties": {
    "interval_ns": { "const": 1000000000 },
    "samples": {
      "type": "array", "minItems": 2,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["offset_ns", "cpu_percent", "rss_bytes", "network_bytes_sent", "network_bytes_received", "disk_bytes_read", "disk_bytes_written", "disk_read_operations", "disk_write_operations", "database_size_bytes", "object_store"],
        "properties": {
          "offset_ns": { "type": "integer", "minimum": 0 },
          "cpu_percent": { "type": "number", "minimum": 0 }, "rss_bytes": { "type": "integer", "minimum": 0 },
          "network_bytes_sent": { "type": "integer", "minimum": 0 }, "network_bytes_received": { "type": "integer", "minimum": 0 },
          "disk_bytes_read": { "type": "integer", "minimum": 0 }, "disk_bytes_written": { "type": "integer", "minimum": 0 },
          "disk_read_operations": { "type": "integer", "minimum": 0 }, "disk_write_operations": { "type": "integer", "minimum": 0 },
          "database_size_bytes": { "type": "integer", "minimum": 0, "description": "Estimated compressed bytes of unique SSTs in the live LSM." },
          "object_store": { "$ref": "#/$defs/objectStoreMetrics" }
        }
      }
    },
    "application_windows": {
      "type": "array",
      "items": { "$ref": "#/$defs/applicationWindow" }
    },
    "durability_windows": {
      "anyOf": [
        { "type": "array", "items": { "$ref": "#/$defs/durabilityWindow" } },
        { "type": "null" }
      ]
    },
    "slatedb_metrics": { "type": "array", "items": { "$ref": "#/$defs/metricSeries" } }
  },
  "$defs": {
    "objectStoreMetrics": {
      "type": "object", "additionalProperties": false,
      "required": ["operations", "requests", "successful_requests", "request_errors", "client_errors", "server_errors", "transport_errors", "errors", "bytes_read", "bytes_written", "operation_bytes_read", "operation_bytes_written"],
      "properties": {
        "operations": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "requests": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "successful_requests": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "request_errors": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "client_errors": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "server_errors": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "transport_errors": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "errors": { "type": "integer", "minimum": 0 },
        "bytes_read": { "type": "integer", "minimum": 0 }, "bytes_written": { "type": "integer", "minimum": 0 },
        "operation_bytes_read": { "type": "integer", "minimum": 0 }, "operation_bytes_written": { "type": "integer", "minimum": 0 }
      }
    },
    "latency": {
      "type": "object", "additionalProperties": false,
      "required": ["count", "p50_ns", "p95_ns", "p99_ns", "p999_ns", "max_ns"],
      "properties": {
        "count": { "type": "integer", "minimum": 1 },
        "p50_ns": { "type": "integer", "minimum": 0 },
        "p95_ns": { "type": "integer", "minimum": 0 },
        "p99_ns": { "type": "integer", "minimum": 0 },
        "p999_ns": { "type": "integer", "minimum": 0 },
        "max_ns": { "type": "integer", "minimum": 0 }
      }
    },
    "nullableLatency": {
      "anyOf": [{ "$ref": "#/$defs/latency" }, { "type": "null" }]
    },
    "applicationWindow": {
      "type": "object", "additionalProperties": false,
      "required": ["start_offset_ns", "duration_ns", "completed_operations", "successful_operations", "errors", "read_payload_bytes", "write_payload_bytes", "read_hits", "read_misses", "return_latency", "return_latency_by_operation", "api_latency", "batch_latency"],
      "properties": {
        "start_offset_ns": { "type": "integer", "minimum": 0 },
        "duration_ns": { "type": "integer", "exclusiveMinimum": 0 },
        "completed_operations": { "type": "integer", "minimum": 0 },
        "successful_operations": { "type": "integer", "minimum": 0 },
        "errors": { "type": "integer", "minimum": 0 },
        "read_payload_bytes": { "type": "integer", "minimum": 0 },
        "write_payload_bytes": { "type": "integer", "minimum": 0 },
        "read_hits": { "type": "integer", "minimum": 0 },
        "read_misses": { "type": "integer", "minimum": 0 },
        "return_latency": { "$ref": "#/$defs/nullableLatency" },
        "return_latency_by_operation": { "type": "object", "additionalProperties": { "$ref": "#/$defs/latency" } },
        "api_latency": { "type": "object", "additionalProperties": { "$ref": "#/$defs/latency" } },
        "batch_latency": { "$ref": "#/$defs/nullableLatency" }
      }
    },
    "durabilityWindow": {
      "type": "object", "additionalProperties": false,
      "required": ["start_offset_ns", "duration_ns", "writes_made_durable", "durability_lag"],
      "properties": {
        "start_offset_ns": { "type": "integer", "minimum": 0 },
        "duration_ns": { "type": "integer", "exclusiveMinimum": 0 },
        "writes_made_durable": { "type": "integer", "minimum": 0 },
        "durability_lag": { "$ref": "#/$defs/nullableLatency" }
      }
    },
    "metricSeries": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "description", "labels", "value_type", "boundaries", "values"],
      "properties": {
        "name": { "type": "string" }, "description": { "type": "string" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "value_type": { "enum": ["counter", "gauge", "up_down_counter", "histogram"] },
        "boundaries": {
          "anyOf": [
            { "type": "array", "items": { "type": "number" } },
            { "type": "null" }
          ]
        },
        "values": {
          "type": "array", "minItems": 2,
          "items": {
            "anyOf": [
              { "type": "integer" },
              { "type": "null" },
              { "$ref": "#/$defs/histogramValue" }
            ]
          }
        }
      }
    },
    "histogramValue": {
      "type": "object", "additionalProperties": false,
      "required": ["count", "sum", "min", "max", "bucket_counts"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "sum": { "type": "number" }, "min": { "type": "number" }, "max": { "type": "number" },
        "bucket_counts": { "type": "array", "items": { "type": "integer", "minimum": 0 } }
      }
    }
  }
}
