{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benchmark.slatedb.io/schema/run.json",
  "title": "SlateDB benchmark run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "golden_id",
    "started_at",
    "finished_at",
    "source",
    "preparation_runner_commits",
    "resolved_configuration",
    "max_parallel",
    "transfer_capacity",
    "results"
  ],
  "properties": {
    "status": { "const": "ok" },
    "golden_id": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slate_version",
        "slate_commit",
        "runner_version",
        "runner_commit",
        "lockfile_sha256"
      ],
      "properties": {
        "slate_version": { "type": "string", "minLength": 1 },
        "slate_commit": { "type": "string", "minLength": 1 },
        "runner_version": { "type": "string", "minLength": 1 },
        "runner_commit": { "type": "string", "minLength": 1 },
        "lockfile_sha256": { "type": "string", "minLength": 1 }
      }
    },
    "preparation_runner_commits": {
      "type": "object",
      "required": ["bulk-load", "compaction"],
      "additionalProperties": false,
      "properties": {
        "bulk-load": { "type": "string", "minLength": 1 },
        "compaction": { "type": "string", "minLength": 1 }
      }
    },
    "resolved_configuration": {
      "type": "object",
      "required": ["bulk-load", "compaction"],
      "minProperties": 3,
      "maxProperties": 12,
      "propertyNames": {
        "enum": [
          "bulk-load",
          "compaction",
          "idle",
          "point-read-uniform",
          "point-read-skewed",
          "point-read-missing",
          "read-heavy",
          "balanced",
          "update-heavy",
          "range-scan",
          "sustained-ingest",
          "transaction-contention"
        ]
      },
      "additionalProperties": { "type": "object" }
    },
    "max_parallel": { "type": "integer", "minimum": 1 },
    "transfer_capacity": {
      "oneOf": [
        { "$ref": "#/$defs/legacyTransferCapacity" },
        { "$ref": "#/$defs/warpTransferCapacity" }
      ]
    },
    "results": {
      "type": "object",
      "required": [
        "preparation/bulk-load/result.json",
        "preparation/compaction/result.json"
      ],
      "minProperties": 4,
      "maxProperties": 22,
      "propertyNames": {
        "pattern": "^(preparation/(bulk-load|compaction)/result|workload/(idle|point-read-uniform|point-read-skewed|point-read-missing|read-heavy|balanced|update-heavy|range-scan|sustained-ingest|transaction-contention)/(result|series))\\.json$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9a-f]{64}$"
      }
    }
  },
  "$defs": {
    "legacyTransferCapacity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "timestamp",
        "scale",
        "runner_type",
        "object_store",
        "endpoint",
        "region",
        "parallel_objects",
        "requests_per_process",
        "max_concurrent_requests",
        "warmup_bytes",
        "measured_bytes",
        "upload",
        "download"
      ],
      "properties": {
        "status": { "const": "ok" },
        "timestamp": { "type": "string", "format": "date-time" },
        "scale": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "runner_type": { "type": "string", "minLength": 1 },
        "object_store": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "parallel_objects": { "type": "integer", "minimum": 1 },
        "requests_per_process": { "type": "integer", "minimum": 1 },
        "max_concurrent_requests": { "type": "integer", "minimum": 1 },
        "warmup_bytes": { "type": "integer", "minimum": 1 },
        "measured_bytes": { "type": "integer", "minimum": 1 },
        "upload": { "$ref": "#/$defs/transferMeasurement" },
        "download": { "$ref": "#/$defs/transferMeasurement" }
      }
    },
    "warpTransferCapacity": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "version": { "const": 3 } } },
          "then": {
            "properties": {
              "benchmarks": { "items": { "required": ["latency_ms"] } }
            }
          }
        }
      ],
      "required": [
        "version",
        "status",
        "timestamp",
        "scale",
        "runner_type",
        "object_store",
        "endpoint",
        "region",
        "tool",
        "benchmarks"
      ],
      "properties": {
        "version": { "enum": [2, 3] },
        "status": { "const": "ok" },
        "timestamp": { "type": "string", "format": "date-time" },
        "scale": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "runner_type": { "type": "string", "minLength": 1 },
        "object_store": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "tool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": { "const": "warp" },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "benchmarks": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": { "$ref": "#/$defs/warpBenchmark" }
        }
      }
    },
    "warpBenchmark": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "operation",
        "object_size_bytes",
        "concurrency",
        "duration_seconds",
        "benchdata"
      ],
      "properties": {
        "name": {
          "enum": ["large-put", "large-get", "small-put", "small-get", "small-list"]
        },
        "operation": { "enum": ["PUT", "GET", "LIST"] },
        "object_size_bytes": { "type": "integer", "minimum": 1 },
        "concurrency": { "type": "integer", "minimum": 1 },
        "duration_seconds": { "type": "integer", "minimum": 1 },
        "latency_ms": { "$ref": "#/$defs/warpLatency" },
        "benchdata": {
          "type": "string",
          "pattern": "^warp/(large-(put|get)|small-(put|get|list))\\.(csv|json)\\.zst$"
        }
      }
    },
    "warpLatency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request"],
      "properties": {
        "request": { "$ref": "#/$defs/warpLatencySummary" },
        "ttfb": { "$ref": "#/$defs/warpLatencySummary" }
      }
    },
    "warpLatencySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["average", "p50", "p90", "p99", "min", "max"],
      "properties": {
        "average": { "type": "number", "minimum": 0 },
        "p50": { "type": "number", "minimum": 0 },
        "p90": { "type": "number", "minimum": 0 },
        "p99": { "type": "number", "minimum": 0 },
        "min": { "type": "number", "minimum": 0 },
        "max": { "type": "number", "minimum": 0 }
      }
    },
    "transferMeasurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["elapsed_seconds", "mib_per_second"],
      "properties": {
        "elapsed_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "mib_per_second": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  }
}
