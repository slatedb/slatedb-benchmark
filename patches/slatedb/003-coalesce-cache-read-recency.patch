+const ACCESS_FLUSH_INTERVAL: Duration = Duration::from_millis(100);
+const MAX_PENDING_ACCESS_PATHS: usize = 16 * 1024;
+// Minimum time between aggregated "access tracker is full" warnings.
+const ACCESS_DROP_LOG_INTERVAL_MS: i64 = 30_000;
+
+#[derive(Debug)]
+struct PendingAccesses {
+    paths: SyncMutex<HashMap<std::path::PathBuf, usize>>,
+    max_paths: usize,
+}
+
+impl PendingAccesses {
+    fn new(max_paths: usize) -> Self {
+        Self {
+            paths: SyncMutex::new(HashMap::with_capacity(max_paths)),
+            max_paths,
+        }
+    }
+
+    fn record(&self, path: std::path::PathBuf, bytes: usize) -> bool {
+        let mut paths = self.paths.lock();
+        if let Some(previous_bytes) = paths.get_mut(&path) {
+            *previous_bytes = bytes;
+            return true;
+        }
+        if paths.len() >= self.max_paths {
+            return false;
+        }
+        paths.insert(path, bytes);
+        true
+    }
+
+    fn drain(&self) -> Vec<FsCacheAccess> {
+        std::mem::take(&mut *self.paths.lock())
+            .into_iter()
+            .collect()
+    }
+
+    #[cfg(test)]
+    fn len(&self) -> usize {
+        self.paths.lock().len()
+    }
+}
 
