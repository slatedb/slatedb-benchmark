+    #[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+    async fn test_embedded_compaction_notifications_avoid_polling() {
+        let os = Arc::new(InMemory::new());
+        let mut options = db_options(Some(compactor_options()));
+        let poll_interval = Duration::from_secs(3600);
+        options.flush_interval = None;
+        options.manifest_poll_interval = poll_interval;
+
+        let compactor_options = options
+            .compactor_options
+            .as_mut()
+            .expect("compactor options must be set");
+        compactor_options.poll_interval = poll_interval;
+        compactor_options.commit_compacted_interval = poll_interval;
+        compactor_options.scheduler_options = SizeTieredCompactionSchedulerOptions {
+            min_compaction_sources: 2,
+            max_compaction_sources: 2,
+            include_size_threshold: 4.0,
+        }
+        .into();
+        compactor_options
+            .worker
+            .as_mut()
+            .expect("embedded worker must be set")
+            .compactions_poll_interval = poll_interval;
+
+        let db = Db::builder(PATH, os)
+            .with_settings(options)
+            .build()
+            .await
+            .unwrap();
+
+        // Let each dispatcher's immediate first tick complete. Further progress
+        // must come from messages because every polling interval is one hour.
+        tokio::time::sleep(Duration::from_millis(100)).await;
+
+        put_and_flush_memtable(&db, b"key", b"value-1").await;
+        put_and_flush_memtable(&db, b"key", b"value-2").await;
+
+        let state =
+            run_for(Duration::from_secs(10), || {
+                let state = read_db_state_core(&db);
+                async move {
+                    (state.tree.l0.is_empty() && state.tree.compacted.len() == 1).then_some(state)
+                }
+            })
+            .await
+            .expect("embedded notifications did not drive compaction");
+
+        assert_eq!(state.tree.compacted[0].sst_views.len(), 1);
+        assert_eq!(
+            db.get(b"key").await.unwrap(),
+            Some(Bytes::from_static(b"value-2"))
+        );
+        db.close().await.unwrap();
+    }
+
     #[tokio::test(flavor = "multi_thread", worker_threads = 2)]
     async fn test_compactor_compacts_only_target_segment() {
         let os = Arc::new(InMemory::new());
