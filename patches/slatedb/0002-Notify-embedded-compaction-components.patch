+    pub(crate) fn with_worker_tx(
+        mut self,
+        worker_tx: Option<async_channel::Sender<WorkerMessage>>,
+    ) -> Self {
+        self.worker_tx = worker_tx;
+        self
+    }
+
+    /// Wakes an embedded worker when the coordinator has persisted work that
+    /// is ready to claim. Distributed workers retain their jittered polling
+    /// ticker as the cross-process discovery path.
+    fn notify_worker_if_ready(&self) {
+        if !self
+            .state()
+            .compactions_with_status(&[CompactionStatus::Scheduled])
+            .any(|compaction| compaction.worker().is_none())
+        {
+            return;
+        }
+        let Some(worker_tx) = &self.worker_tx else {
+            return;
+        };
+        #[allow(clippy::disallowed_methods)]
+        if let Err(e) = worker_tx.try_send(WorkerMessage::PollCompactions) {
+            debug!(
+                "failed to notify embedded compaction worker (likely shutdown) [error={:?}]",
+                e
+            );
+        }
+    }
+
     fn state(&self) -> &CompactorState {
         &self.state_writer.state
     }
@@ -4807,6 +4854,47 @@ mod tests {
         assert!(last_ts > starting_last_ts);
