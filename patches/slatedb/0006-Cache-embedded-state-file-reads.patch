+struct TransactionalCache<T> {
+    latest: Option<(MonotonicId, T)>,
+    refresh_required: bool,
+}
+
+/// A read-through, write-through cache for the latest value in a sequenced store.
+///
+/// This wrapper is intended for clients in one process that share the same instance.
+/// Cache hits still check the durable boundary, so an out-of-process garbage collector
+/// can invalidate a cached value. Successful checked writes publish to the cache. A
+/// write conflict forces the next read through to storage unless a newer cached value
+/// already explains the conflict.
+pub struct CachedTransactionalStorageProtocol<T: Send + Sync> {
+    inner: Arc<dyn SequencedStorageProtocol<T>>,
+    cache: Mutex<TransactionalCache<T>>,
+    kind: &'static str,
+    directory: String,
+}
+
+impl<T: Send + Sync> CachedTransactionalStorageProtocol<T> {
+    pub fn new(
+        inner: Arc<dyn SequencedStorageProtocol<T>>,
+        kind: &'static str,
+        directory: String,
+    ) -> Self {
+        Self {
+            inner,
+            cache: Mutex::new(TransactionalCache {
+                latest: None,
+                refresh_required: false,
+            }),
+            kind,
+            directory,
+        }
+    }
+}
+
+impl<T: Clone + Send + Sync> CachedTransactionalStorageProtocol<T> {
+    fn cached_latest(&self) -> Option<(MonotonicId, T)> {
+        let cache = self.cache.lock();
+        (!cache.refresh_required)
+            .then(|| cache.latest.clone())
+            .flatten()
+    }
+
+    fn invalidate_if_current(&self, id: MonotonicId) {
+        let mut cache = self.cache.lock();
+        match cache.latest.as_ref() {
+            Some((cached_id, _)) if *cached_id > id => return,
+            Some((cached_id, _)) if *cached_id == id => cache.latest = None,
+            _ => {}
+        }
+        cache.refresh_required = true;
+    }
+
+    /// Merges a checked remote read into the cache without allowing the shared
+    /// view to move backward. Returns whether the selected value still needs a
+    /// boundary check because it came from the cache rather than the remote read.
+    fn merge_remote(&self, remote: Option<(MonotonicId, T)>) -> (Option<(MonotonicId, T)>, bool) {
+        let mut cache = self.cache.lock();
+        match (cache.latest.as_ref(), remote) {
+            (Some((cached_id, cached_value)), Some((remote_id, _remote_value)))
+                if *cached_id > remote_id =>
+            {
+                (Some((*cached_id, cached_value.clone())), true)
+            }
+            (_, Some((remote_id, remote_value))) => {
+                cache.latest = Some((remote_id, remote_value.clone()));
+                cache.refresh_required = false;
+                (Some((remote_id, remote_value)), false)
+            }
+            (Some((cached_id, cached_value)), None) => {
+                (Some((*cached_id, cached_value.clone())), true)
+            }
+            (None, None) => {
+                cache.refresh_required = false;
+                (None, false)
+            }
+        }
+    }
+
+    fn update_after_write(&self, id: MonotonicId, value: &T) {
+        let mut cache = self.cache.lock();
+        if cache
+            .latest
+            .as_ref()
+            .is_none_or(|(cached_id, _)| id >= *cached_id)
+        {
+            cache.latest = Some((id, value.clone()));
+            cache.refresh_required = false;
+        }
+    }
+
+    fn conflict_explained_by_cache(&self, current_id: Option<MonotonicId>) -> bool {
+        self.cache
+            .lock()
+            .latest
+            .as_ref()
+            .is_some_and(|(cached_id, _)| current_id.is_none_or(|id| *cached_id > id))
+    }
+
+    fn require_refresh_unless_newer(&self, current_id: Option<MonotonicId>) {
+        let mut cache = self.cache.lock();
+        if cache
+            .latest
+            .as_ref()
+            .is_some_and(|(cached_id, _)| current_id.is_none_or(|id| *cached_id > id))
+        {
+            return;
+        }
+        cache.refresh_required = true;
+    }
+
+    async fn check_cached(&self, id: MonotonicId) -> Result<(), TransactionalObjectError> {
+        let start = Instant::now();
+        let result = self.inner.check(id).await;
+        let status = match &result {
+            Ok(()) => "ok",
+            Err(TransactionalObjectError::ObjectVersionExists) => "invalidated",
+            Err(_) => "error",
+        };
+        info!(
+            "state file cache hit [kind={}, directory={}, id={}, elapsed_ms={:.3}, status={}]",
+            self.kind,
+            self.directory,
+            id.id(),
+            start.elapsed().as_secs_f64() * 1000.0,
+            status,
+        );
+        result
+    }
+}
+
+#[async_trait]
+impl<T: Clone + Send + Sync> TransactionalStorageProtocol<T, MonotonicId>
+    for CachedTransactionalStorageProtocol<T>
+{
+    async fn write(
+        &self,
+        current_id: Option<MonotonicId>,
+        new_value: &T,
+    ) -> Result<MonotonicId, TransactionalObjectError> {
+        if self.conflict_explained_by_cache(current_id) {
+            return Err(TransactionalObjectError::ObjectVersionExists);
+        }
+
+        match self.inner.write(current_id, new_value).await {
+            Ok(id) => {
+                self.update_after_write(id, new_value);
+                Ok(id)
+            }
+            Err(error) if error.is_sequenced_write_conflict() => {
+                self.require_refresh_unless_newer(current_id);
+                Err(error)
+            }
+            Err(error) => Err(error),
+        }
+    }
+
+    async fn try_read_latest(&self) -> Result<Option<(MonotonicId, T)>, TransactionalObjectError> {
+        loop {
+            if let Some((id, value)) = self.cached_latest() {
+                match self.check_cached(id).await {
+                    Ok(()) => return Ok(Some((id, value))),
+                    Err(TransactionalObjectError::ObjectVersionExists) => {
+                        self.invalidate_if_current(id);
+                    }
+                    Err(error) => return Err(error),
+                }
+            }
+
+            let remote = self.inner.try_read_latest().await?;
+            let (selected, check_boundary) = self.merge_remote(remote);
+            let Some((id, value)) = selected else {
+                return Ok(None);
+            };
+            if !check_boundary {
+                return Ok(Some((id, value)));
+            }
+            match self.check_cached(id).await {
+                Ok(()) => return Ok(Some((id, value))),
+                Err(TransactionalObjectError::ObjectVersionExists) => {
+                    self.invalidate_if_current(id);
+                }
+                Err(error) => return Err(error),
+            }
+        }
+    }
+}
