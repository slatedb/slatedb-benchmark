@@ -95,6 +100,45 @@ impl<T> ObjectStoreSequencedStorageProtocol<T> {
             _ => Err(TransactionalObjectError::InvalidObjectState),
         }
     }
+
+    async fn try_read_file(
+        &self,
+        id: MonotonicId,
+    ) -> Result<Option<(T, usize)>, TransactionalObjectError> {
+        let start = Instant::now();
+        let path = self.path_for(id);
+        let result = match self.object_store.get(&path).await {
+            Ok(obj) => match obj.bytes().await {
+                Ok(bytes) => {
+                    let size_bytes = bytes.len();
+                    self.codec
+                        .decode(&bytes)
+                        .map(|value| Some((value, size_bytes)))
+                        .map_err(CallbackError)
+                }
+                Err(e) => Err(TransactionalObjectError::from(e)),
+            },
+            Err(e) => match e {
+                Error::NotFound { .. } => Ok(None),
+                _ => Err(TransactionalObjectError::from(e)),
+            },
+        };
+        let (size_bytes, status) = match &result {
+            Ok(Some((_, size_bytes))) => (*size_bytes, "ok"),
+            Ok(None) => (0, "not_found"),
+            Err(_) => (0, "error"),
+        };
+        info!(
+            "state file read [kind={}, directory={}, id={}, size_bytes={}, elapsed_ms={:.3}, status={}]",
+            self.file_suffix,
+            self.dir_path,
+            id.id(),
+            size_bytes,
+            start.elapsed().as_secs_f64() * 1000.0,
+            status,
+        );
+        result
+    }
 }
 
