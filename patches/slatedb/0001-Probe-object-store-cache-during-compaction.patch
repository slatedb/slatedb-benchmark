From: Chris Riccomini <criccomini@apache.org>
Date: Wed, 22 Jul 2026 09:46:15 -0700
Subject: [PATCH] Probe object store cache during compaction

---
 .../src/cached_object_store/object_store.rs   | 111 ++++++++++++++++--
 slatedb/src/cached_object_store/policy.rs     |  30 +++--
 2 files changed, 121 insertions(+), 20 deletions(-)

diff --git a/slatedb/src/cached_object_store/object_store.rs b/slatedb/src/cached_object_store/object_store.rs
index 0f8f71c7..9ba17678 100644
--- a/slatedb/src/cached_object_store/object_store.rs
+++ b/slatedb/src/cached_object_store/object_store.rs
@@ -258,13 +258,33 @@ impl CachedObjectStore {
         location: &Path,
         opts: GetOptions,
         force_refresh: bool,
+        admit_on_miss: bool,
     ) -> object_store::Result<GetResult> {
+        let prefetched_head = if admit_on_miss {
+            self.maybe_prefetch_range(location, opts.clone()).await?
+        } else {
+            let entry = self.cache_storage.entry(location, self.part_size_bytes);
+            match entry.read_head().await {
+                Ok(Some((meta, attributes))) => PrefetchedHead {
+                    meta,
+                    attributes,
+                    extensions: Extensions::new(),
+                    head_source: ReadResultSource::Disk,
+                },
+                // Without a cached head there is no committed cache entry to
+                // probe. Preserve the original request and stream the result
+                // directly from upstream without admitting it.
+                Ok(None) | Err(_) => {
+                    return self.object_store.get_opts(location, opts).await;
+                }
+            }
+        };
         let PrefetchedHead {
             meta,
             attributes,
             extensions,
             head_source,
-        } = self.maybe_prefetch_range(location, opts.clone()).await?;
+        } = prefetched_head;
 
         let get_range = opts.range.clone();
         let range = self.canonicalize_range(get_range, meta.size)?;
@@ -280,7 +300,13 @@ impl CachedObjectStore {
                 async move {
                     this.stats.object_store_cache_part_access.increment(1);
                     let (bytes, part_source) = this
-                        .read_part(&location, part_id, range_in_part, force_refresh)
+                        .read_part(
+                            &location,
+                            part_id,
+                            range_in_part,
+                            force_refresh,
+                            admit_on_miss,
+                        )
                         .await?;
                     if head_source == ReadResultSource::Disk
                         && part_source == ReadResultSource::Disk
@@ -520,6 +546,7 @@ impl CachedObjectStore {
         part_id: PartID,
         range_in_part: Range<usize>,
         force_refresh: bool,
+        admit_on_miss: bool,
     ) -> BoxFuture<'static, object_store::Result<(Bytes, ReadResultSource)>> {
         let this = self.clone();
         let location = location.clone();
@@ -531,6 +558,27 @@ impl CachedObjectStore {
                 }
             }
 
+            // A probe miss reads upstream without changing the cache.
+            if !admit_on_miss {
+                let part_range = Range {
+                    start: (part_id * this.part_size_bytes) as u64,
+                    end: ((part_id + 1) * this.part_size_bytes) as u64,
+                };
+                let bytes = this
+                    .object_store
+                    .get_opts(
+                        &location,
+                        GetOptions {
+                            range: Some(GetRange::Bounded(part_range)),
+                            ..Default::default()
+                        },
+                    )
+                    .await?
+                    .bytes()
+                    .await?;
+                return Ok((bytes.slice(range_in_part), ReadResultSource::Upstream));
+            }
+
             // Cache miss, so we need to fetch from the object store.
             // Read Part — deduplicate concurrent fetches of the same part.
             // The SingleFlight fetches the full part and saves it to cache; each
@@ -712,8 +760,9 @@ impl ObjectStore for CachedObjectStore {
         }
         match self.get_policy.get_action(tag.as_ref()) {
             GetAction::Bypass => self.object_store.get_opts(location, options).await,
-            GetAction::Refetch => self.cached_get_opts(location, options, true).await,
-            GetAction::ReadThrough => self.cached_get_opts(location, options, false).await,
+            GetAction::Probe => self.cached_get_opts(location, options, false, false).await,
+            GetAction::Refetch => self.cached_get_opts(location, options, true, true).await,
+            GetAction::ReadThrough => self.cached_get_opts(location, options, false, true).await,
         }
     }
 
@@ -1225,6 +1274,7 @@ mod tests {
                     ..Default::default()
                 },
                 false,
+                true,
             )
             .await
             .expect("cache miss should fetch from inner store");
@@ -1491,6 +1541,7 @@ mod tests {
                         ..Default::default()
                     },
                     false,
+                    true,
                 )
                 .await;
             match (want, got) {
@@ -1754,7 +1805,7 @@ mod tests {
                     range: Some(GetRange::Bounded(0..1024)),
                     ..Default::default()
                 };
-                let result = store.cached_get_opts(&p, opts, false).await?;
+                let result = store.cached_get_opts(&p, opts, false, true).await?;
                 result.bytes().await
             }));
         }
@@ -1861,7 +1912,7 @@ mod tests {
                     range,
                     ..Default::default()
                 };
-                store.cached_get_opts(&p, opts, false).await
+                store.cached_get_opts(&p, opts, false, true).await
             }));
         }
 
@@ -1998,7 +2049,7 @@ mod tests {
             ..Default::default()
         };
         let result = cached_store
-            .cached_get_opts(&path, prime_opts, false)
+            .cached_get_opts(&path, prime_opts, false, true)
             .await
             .unwrap();
         let _ = result.bytes().await.unwrap();
@@ -2009,7 +2060,7 @@ mod tests {
             range: Some(GetRange::Bounded(0..512)),
             ..Default::default()
         };
-        let result = cached_store.cached_get_opts(&path, opts, false).await;
+        let result = cached_store.cached_get_opts(&path, opts, false, true).await;
         assert!(result.is_ok());
         let bytes = result.unwrap().bytes().await.unwrap();
         assert_eq!(&bytes[..], &payload[..512]);
@@ -2246,7 +2297,7 @@ mod tests {
     }
 
     #[tokio::test]
-    async fn test_compactor_get_bypasses_cache() {
+    async fn test_compactor_get_probe_miss_does_not_cache() {
         let upstream: Arc<dyn ObjectStore> = Arc::new(object_store::memory::InMemory::new());
         let store = policy_test_store(upstream.clone(), CachePutConfig::default());
 
@@ -2257,7 +2308,7 @@ mod tests {
             .await
             .unwrap();
 
-        // A compactor read returns the bytes but caches nothing.
+        // A compactor probe miss returns the bytes but caches nothing.
         let got = store
             .get_opts(
                 &location,
@@ -2274,7 +2325,7 @@ mod tests {
         assert_eq!(got, payload);
         assert_eq!(cached_part_count(&store, &location).await, 0);
 
-        // A main read of the same object caches it: the bypass is compactor specific.
+        // A main read of the same object takes the normal read-through path.
         store
             .get_opts(
                 &location,
@@ -2442,6 +2493,44 @@ mod tests {
         );
     }
 
+    #[tokio::test]
+    async fn test_compactor_get_serves_cached_flush() {
+        let upstream: Arc<dyn ObjectStore> = Arc::new(object_store::memory::InMemory::new());
+        let store = policy_test_store(
+            upstream.clone(),
+            CachePutConfig {
+                cache_on_flush: true,
+                cache_on_compaction: false,
+            },
+        );
+
+        let location = Path::from("compacted/01.sst");
+        let payload = gen_rand_bytes(2048);
+        let flush_tag = ObjectStoreCallTag::new(TableStoreKind::Main, SstType::Compacted);
+        store
+            .put_opts(
+                &location,
+                PutPayload::from_bytes(payload.clone()),
+                put_opts_tagged(flush_tag),
+            )
+            .await
+            .unwrap();
+
+        // Prove the compactor is served from the cached flush rather than the
+        // durable object by removing the upstream copy before reading it.
+        upstream.delete(&location).await.unwrap();
+        let compactor_tag = ObjectStoreCallTag::new(TableStoreKind::Compactor, SstType::Compacted);
+        let got = store
+            .get_opts(&location, get_opts_tagged(compactor_tag))
+            .await
+            .unwrap()
+            .bytes()
+            .await
+            .unwrap();
+
+        assert_eq!(got, payload);
+    }
+
     #[tokio::test]
     async fn test_wal_read_bypasses_cache() {
         let upstream: Arc<dyn ObjectStore> = Arc::new(object_store::memory::InMemory::new());
diff --git a/slatedb/src/cached_object_store/policy.rs b/slatedb/src/cached_object_store/policy.rs
index d850fce1..3c351012 100644
--- a/slatedb/src/cached_object_store/policy.rs
+++ b/slatedb/src/cached_object_store/policy.rs
@@ -21,14 +21,19 @@ impl GetPolicy for DefaultGetPolicy {
             return GetAction::Bypass;
         };
 
-        // Compactor reads are one shot large scans that are not worth caching
-        // and GC doesn't issue any reads that would benefit from caching.
-        // Both bypass the cache. WAL reads are mainly during startup so they
-        // bypass the cache.
-        if matches!(tag.kind, TableStoreKind::Compactor | TableStoreKind::GC)
-            || tag.sst_type == SstType::Wal
-        {
+        // GC doesn't issue any reads that would benefit from caching. WAL reads
+        // are mainly during startup. Both bypass the cache.
+        if tag.kind == TableStoreKind::GC || tag.sst_type == SstType::Wal {
             GetAction::Bypass
+        } else if tag.kind == TableStoreKind::Compactor {
+            // Compaction scans should reuse flushed SSTs already present in the
+            // cache, but must not admit one-shot misses. On retry, bypass the
+            // cache so a corrupt cached part cannot be served again.
+            if tag.retry.is_some() {
+                GetAction::Bypass
+            } else {
+                GetAction::Probe
+            }
         } else if tag.retry.is_some() {
             // A reissued, non-bypassed read refetches.
             GetAction::Refetch
@@ -91,6 +96,12 @@ pub(crate) enum GetAction {
     ///
     /// Used for things like compaction input scans and for WAL reads.
     Bypass,
+    /// Serve from the cache when present. On a miss, fetch from upstream
+    /// without admitting the object or part to the cache.
+    ///
+    /// Used by compaction input scans to reuse cached flush outputs without
+    /// polluting the cache with older compaction inputs.
+    Probe,
     /// Drop any cached entry for the path, refetches from upstream and
     /// re-caches.
     ///
@@ -157,10 +168,11 @@ mod tests {
     }
 
     #[rstest]
-    // Compactor and GC reads bypass regardless of sst type or retry.
+    // A normal compactor read probes the cache, while a retry bypasses it so a
+    // corrupt cached part is not served twice.
     #[case(
         Some(tag(TableStoreKind::Compactor, SstType::Compacted, None)),
-        GetAction::Bypass
+        GetAction::Probe
     )]
     #[case(
         Some(tag(
