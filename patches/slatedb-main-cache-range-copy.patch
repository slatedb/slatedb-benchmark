+    #[test]
+    fn test_copy_part_range_does_not_retain_full_part() {
+        let part = Bytes::from(vec![7_u8; 4 * 1024 * 1024]);
+        let range = 1024..5120;
+        let source_range_ptr = part[range.clone()].as_ptr();
