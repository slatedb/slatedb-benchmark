{
  "name": "slatedb-benchmark-site",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "mock-data": "node scripts/generate-mock-results.mjs",
    "dev:mock": "npm run mock-data && BENCHMARK_RESULTS_ROOT=../.mock-results/results astro dev",
    "build": "astro check && astro build",
    "build:mock": "npm run mock-data && BENCHMARK_RESULTS_ROOT=../.mock-results/results npm run build",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@fontsource/inter": "^5.2.6",
    "astro": "^7.0.9",
    "chart.js": "^4.4.9",
    "smol-toml": "^1.7.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3"
  }
}
