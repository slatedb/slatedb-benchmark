---
import type { BenchmarkResult, PricingTable } from '../lib/results';

interface Props {
  result: BenchmarkResult;
  pricing: PricingTable;
}

const { result, pricing } = Astro.props;
const basis = {
  elapsed_ns: result.elapsed_ns,
  successful_operations: result.application.successful_operations,
  average_database_size_bytes: result.storage.average_database_size_bytes,
  requests: result.storage.object_store_requests,
};
---

<section
  class="detail-region cost-region"
  aria-labelledby="cost-title"
  data-cost-calculator
  data-pricing={JSON.stringify(pricing)}
  data-basis={JSON.stringify(basis)}
>
  <div class="section-heading cost-heading">
    <div>
      <h2 id="cost-title">Cost calculator</h2>
      <p>Estimate object-store cost using this run’s request mix, storage footprint, and execution time.</p>
    </div>
    <div class="cost-controls">
      <label>
        <span>Provider</span>
        <select data-cost-provider aria-label="Object store provider">
          {pricing.providers.map((provider) => <option value={provider.id}>{provider.name}</option>)}
        </select>
      </label>
      <label>
        <span>Operations</span>
        <input data-cost-operations aria-label="Projected application operations" type="number" min="1" step="100000" value="1000000" />
      </label>
    </div>
  </div>

  <div class="cost-output" aria-live="polite">
    <div class="cost-total">
      <span>Estimated object-store cost</span>
      <strong data-cost-total>$0.000000</strong>
      <small data-cost-scale></small>
    </div>
    <dl class="cost-breakdown">
      <div><dt>Requests</dt><dd data-cost-requests>$0.000000</dd></div>
      <div><dt>Storage</dt><dd data-cost-storage>$0.000000</dd></div>
      <div><dt>Same-region transfer</dt><dd>$0.00</dd></div>
    </dl>
  </div>

  <div class="cost-context">
    <span data-cost-basis></span>
    <span>Free tiers, discounts, and taxes are excluded.</span>
    <a data-cost-source href={pricing.providers[0]?.source}>Provider pricing</a>
    <a href="/raw/prices.json">Raw price table</a>
  </div>
</section>

<script>
  type PricingProvider = {
    id: string;
    name: string;
    region: string;
    region_id: string;
    storage_class: string;
    source: string;
    storage_per_gib_month: number;
    requests_per_1000: Record<string, number>;
  };
  type PricingTable = {
    currency: string;
    units: { gib_bytes: number; month_days: number };
    providers: PricingProvider[];
  };
  type CostBasis = {
    elapsed_ns: number;
    successful_operations: number;
    average_database_size_bytes: number;
    requests: Record<string, number>;
  };

  document.querySelectorAll<HTMLElement>('[data-cost-calculator]').forEach((calculator) => {
    const pricing = JSON.parse(calculator.dataset.pricing || '{}') as PricingTable;
    const basis = JSON.parse(calculator.dataset.basis || '{}') as CostBasis;
    const providerSelect = calculator.querySelector<HTMLSelectElement>('[data-cost-provider]');
    const operationsInput = calculator.querySelector<HTMLInputElement>('[data-cost-operations]');
    const totalOutput = calculator.querySelector<HTMLElement>('[data-cost-total]');
    const requestOutput = calculator.querySelector<HTMLElement>('[data-cost-requests]');
    const storageOutput = calculator.querySelector<HTMLElement>('[data-cost-storage]');
    const scaleOutput = calculator.querySelector<HTMLElement>('[data-cost-scale]');
    const basisOutput = calculator.querySelector<HTMLElement>('[data-cost-basis]');
    const sourceLink = calculator.querySelector<HTMLAnchorElement>('[data-cost-source]');

    const currency = (value: number) => {
      const digits = value === 0 ? 2 : value < 0.01 ? 6 : value < 1 ? 4 : 2;
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: pricing.currency,
        minimumFractionDigits: digits,
        maximumFractionDigits: digits,
      }).format(value);
    };
    const rate = (value: number) => new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: pricing.currency,
      minimumFractionDigits: 3,
      maximumFractionDigits: 5,
    }).format(value);

    const render = () => {
      const provider = pricing.providers.find((candidate) => candidate.id === providerSelect?.value)
        || pricing.providers[0];
      if (!provider) return;
      const projectedOperations = Math.max(1, Number(operationsInput?.value) || 1);
      const scale = basis.successful_operations > 0
        ? projectedOperations / basis.successful_operations
        : 0;
      const requestCost = Object.entries(basis.requests).reduce(
        (sum, [operation, count]) => sum + count * scale / 1000
          * (provider.requests_per_1000[operation] || 0),
        0,
      );
      const elapsedSeconds = basis.elapsed_ns / 1e9 * scale;
      const storageGib = basis.average_database_size_bytes / pricing.units.gib_bytes;
      const storageCost = storageGib
        * elapsedSeconds / (pricing.units.month_days * 86400)
        * provider.storage_per_gib_month;

      if (totalOutput) totalOutput.textContent = currency(requestCost + storageCost);
      if (requestOutput) requestOutput.textContent = currency(requestCost);
      if (storageOutput) storageOutput.textContent = currency(storageCost);
      if (scaleOutput) {
        scaleOutput.textContent = `for ${projectedOperations.toLocaleString('en-US')} application operations`;
      }
      if (basisOutput) {
        basisOutput.textContent = `${provider.storage_class} · ${provider.region} (${provider.region_id}) · ${rate(provider.storage_per_gib_month)}/GiB-month`;
      }
      if (sourceLink) sourceLink.href = provider.source;
    };

    providerSelect?.addEventListener('change', render);
    operationsInput?.addEventListener('input', render);
    render();
  });
</script>
