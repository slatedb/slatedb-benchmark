---
import type { BenchmarkResult, PricingTable } from '../lib/results';

interface Props {
  result: BenchmarkResult;
  pricing: PricingTable;
}

const { result, pricing } = Astro.props;
const requests = result.storage.object_store_requests;
const basis = {
  elapsed_ns: result.elapsed_ns,
  database_size_bytes: result.storage.database_size_bytes,
};
const operationOrder = ['get', 'put', 'list', 'delete', 'head', 'copy', 'create_multipart', 'complete_multipart', 'abort_multipart'];
const requestEntries = Object.entries(requests)
  .filter(([, count]) => count > 0)
  .sort(([left], [right]) => operationOrder.indexOf(left) - operationOrder.indexOf(right));
const operationLabel = (operation: string) => operation.replaceAll('_', ' ');
---

<section
  class="detail-region cost-region"
  aria-labelledby="cost-title"
  data-cost-section
  data-pricing={JSON.stringify(pricing)}
  data-basis={JSON.stringify(basis)}
>
  <div class="section-heading cost-heading">
    <div>
      <h2 id="cost-title">Cost</h2>
      <p>30-day estimate using this run’s request rate and final storage footprint.</p>
    </div>
    <div class="cost-controls">
      <label>
        <span>Provider</span>
        <select data-cost-provider aria-label="Object store provider">
          {pricing.providers.map((provider) => <option value={provider.id}>{provider.name}</option>)}
        </select>
      </label>
    </div>
  </div>

  <div class="cost-output" aria-live="polite">
    <div class="cost-total">
      <span>Estimated monthly total</span>
      <strong data-cost-total>$0.000000</strong>
      <small>per 30-day month</small>
    </div>
    <dl class="cost-breakdown">
      <div><dt>Requests</dt><dd data-cost-requests>$0.000000</dd></div>
      <div><dt>Storage</dt><dd data-cost-storage>$0.000000</dd></div>
    </dl>
  </div>

  <div class="cost-request-detail">
    <h3>Request cost by operation</h3>
    <div class="table-scroll">
      <table class="cost-request-table">
        <thead>
          <tr>
            <th scope="col">Operation</th>
            <th scope="col">Monthly requests</th>
            <th scope="col">Rate / 1k</th>
            <th scope="col">Monthly cost</th>
          </tr>
        </thead>
        <tbody>
          {requestEntries.map(([operation, count]) => (
            <tr data-cost-operation={operation} data-request-count={count}>
              <th scope="row">{operationLabel(operation)}</th>
              <td data-cost-monthly-requests>—</td>
              <td data-cost-operation-rate>—</td>
              <td data-cost-operation-total>—</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <div class="cost-context">
    <span data-cost-basis></span>
    <span>Free tiers, credits, discounts, and taxes are excluded.</span>
    <span>Compute and storage are assumed to share a region.</span>
    <a data-cost-source href={pricing.providers[0]?.source}>Provider pricing</a>
    <a href="/raw/prices.json">Raw price table</a>
  </div>
</section>

<script>
  type PricingProvider = {
    id: string;
    name: string;
    region: string;
    region_id: string;
    storage_class: string;
    source: string;
    storage_per_gib_month: number;
    requests_per_1000: Record<string, number>;
  };
  type PricingTable = {
    currency: string;
    units: { gib_bytes: number; month_days: number };
    providers: PricingProvider[];
  };
  type CostBasis = {
    elapsed_ns: number;
    database_size_bytes: number;
  };

  document.querySelectorAll<HTMLElement>('[data-cost-section]').forEach((section) => {
    const pricing = JSON.parse(section.dataset.pricing || '{}') as PricingTable;
    const basis = JSON.parse(section.dataset.basis || '{}') as CostBasis;
    const providerSelect = section.querySelector<HTMLSelectElement>('[data-cost-provider]');
    const totalOutput = section.querySelector<HTMLElement>('[data-cost-total]');
    const requestOutput = section.querySelector<HTMLElement>('[data-cost-requests]');
    const storageOutput = section.querySelector<HTMLElement>('[data-cost-storage]');
    const basisOutput = section.querySelector<HTMLElement>('[data-cost-basis]');
    const sourceLink = section.querySelector<HTMLAnchorElement>('[data-cost-source]');
    const operationRows = [...section.querySelectorAll<HTMLTableRowElement>('[data-cost-operation]')];

    const currency = (value: number) => {
      const digits = value === 0 ? 2 : value < 0.01 ? 6 : value < 1 ? 4 : 2;
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: pricing.currency,
        minimumFractionDigits: digits,
        maximumFractionDigits: digits,
      }).format(value);
    };
    const rate = (value: number) => new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: pricing.currency,
      minimumFractionDigits: 3,
      maximumFractionDigits: 5,
    }).format(value);
    const requestCount = (value: number) => new Intl.NumberFormat('en-US', {
      maximumFractionDigits: 0,
    }).format(value);

    const render = () => {
      const provider = pricing.providers.find((candidate) => candidate.id === providerSelect?.value)
        || pricing.providers[0];
      if (!provider) return;
      const elapsedSeconds = basis.elapsed_ns / 1e9;
      const monthSeconds = pricing.units.month_days * 86400;
      const requestScale = elapsedSeconds > 0 ? monthSeconds / elapsedSeconds : 0;
      const requestCost = operationRows.reduce((sum, row) => {
        const operation = row.dataset.costOperation || '';
        const monthlyRequests = Number(row.dataset.requestCount || 0) * requestScale;
        const operationRate = provider.requests_per_1000[operation] || 0;
        const operationCost = monthlyRequests / 1000 * operationRate;
        const monthlyRequestsOutput = row.querySelector<HTMLElement>('[data-cost-monthly-requests]');
        const rateOutput = row.querySelector<HTMLElement>('[data-cost-operation-rate]');
        const costOutput = row.querySelector<HTMLElement>('[data-cost-operation-total]');
        if (monthlyRequestsOutput) monthlyRequestsOutput.textContent = requestCount(monthlyRequests);
        if (rateOutput) rateOutput.textContent = rate(operationRate);
        if (costOutput) costOutput.textContent = currency(operationCost);
        return sum + operationCost;
      }, 0);
      const storageGib = basis.database_size_bytes / pricing.units.gib_bytes;
      const storageCost = storageGib * provider.storage_per_gib_month;

      if (totalOutput) totalOutput.textContent = currency(requestCost + storageCost);
      if (requestOutput) requestOutput.textContent = currency(requestCost);
      if (storageOutput) storageOutput.textContent = currency(storageCost);
      if (basisOutput) {
        basisOutput.textContent = `${provider.storage_class} · ${provider.region} (${provider.region_id}) · ${rate(provider.storage_per_gib_month)}/GiB-month`;
      }
      if (sourceLink) sourceLink.href = provider.source;
    };

    providerSelect?.addEventListener('change', render);
    render();
  });
</script>
