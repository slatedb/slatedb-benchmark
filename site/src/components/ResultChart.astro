---
import type { ResultRoute } from '../lib/results';

interface Props {
  siblings: ResultRoute[];
  selected: string;
}

const { siblings, selected } = Astro.props;
const chartData = siblings.map(({ variant, result }) => ({
  variant,
  selected: variant === selected,
  p50: result.application.return_latency.p50_ns / 1e6,
  p95: result.application.return_latency.p95_ns / 1e6,
  p99: result.application.return_latency.p99_ns / 1e6,
  p999: result.application.return_latency.p999_ns / 1e6,
  throughput: result.application.accepted_ops_per_second,
}));
---

<section class="chart-region" aria-labelledby="chart-title">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Variant comparison</p>
      <h2 id="chart-title">Return latency</h2>
    </div>
    <div class="chart-toggle" role="group" aria-label="Chart metric">
      <button type="button" data-chart-mode="latency" aria-pressed="true">Latency</button>
      <button type="button" data-chart-mode="throughput" aria-pressed="false">Throughput</button>
    </div>
  </div>
  <div class="canvas-wrap">
    <canvas id="result-chart" data-results={JSON.stringify(chartData)} aria-describedby="chart-table"></canvas>
  </div>
  <div class="table-scroll chart-fallback" id="chart-table">
    <table>
      <thead><tr><th>Variant</th><th>p50</th><th>p95</th><th>p99</th><th>p99.9</th><th>Ops/s</th></tr></thead>
      <tbody>
        {chartData.map((row) => (
          <tr class:list={{ selected: row.selected }}>
            <th scope="row">{row.variant}</th>
            <td>{row.p50.toFixed(2)} ms</td><td>{row.p95.toFixed(2)} ms</td>
            <td>{row.p99.toFixed(2)} ms</td><td>{row.p999.toFixed(2)} ms</td>
            <td>{Math.round(row.throughput).toLocaleString()}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<script>
  import Chart from 'chart.js/auto';

  const canvas = document.querySelector<HTMLCanvasElement>('#result-chart');
  if (canvas) {
    const rows = JSON.parse(canvas.dataset.results || '[]');
    const terracotta = '#b26844';
    const ink = '#1f2a37';
    const muted = '#8b94a3';
    const chart = new Chart(canvas, {
      type: 'bar',
      data: {
        labels: rows.map((row: { variant: string }) => row.variant),
        datasets: [
          { label: 'p50', data: rows.map((row: { p50: number }) => row.p50), backgroundColor: muted },
          { label: 'p95', data: rows.map((row: { p95: number }) => row.p95), backgroundColor: '#5e6878' },
          { label: 'p99', data: rows.map((row: { p99: number }) => row.p99), backgroundColor: ink },
          { label: 'p99.9', data: rows.map((row: { p999: number }) => row.p999), backgroundColor: terracotta },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 320, easing: 'easeOutQuart' },
        scales: {
          x: { grid: { display: false }, ticks: { maxRotation: 28, minRotation: 0 } },
          y: { beginAtZero: true, title: { display: true, text: 'Milliseconds' }, grid: { color: 'rgba(15,22,32,.07)' } },
        },
        plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, boxWidth: 8 } } },
      },
    });

    document.querySelectorAll<HTMLButtonElement>('[data-chart-mode]').forEach((button) => {
      button.addEventListener('click', () => {
        const mode = button.dataset.chartMode;
        document.querySelectorAll<HTMLButtonElement>('[data-chart-mode]').forEach((item) =>
          item.setAttribute('aria-pressed', String(item === button)),
        );
        const heading = document.querySelector('#chart-title');
        if (mode === 'throughput') {
          chart.data.datasets = [{ label: 'Accepted ops/s', data: rows.map((row: { throughput: number }) => row.throughput), backgroundColor: terracotta }];
          if (chart.options.scales?.y && 'title' in chart.options.scales.y) chart.options.scales.y.title!.text = 'Operations / second';
          if (heading) heading.textContent = 'Accepted throughput';
        } else {
          chart.data.datasets = [
            { label: 'p50', data: rows.map((row: { p50: number }) => row.p50), backgroundColor: muted },
            { label: 'p95', data: rows.map((row: { p95: number }) => row.p95), backgroundColor: '#5e6878' },
            { label: 'p99', data: rows.map((row: { p99: number }) => row.p99), backgroundColor: ink },
            { label: 'p99.9', data: rows.map((row: { p999: number }) => row.p999), backgroundColor: terracotta },
          ];
          if (chart.options.scales?.y && 'title' in chart.options.scales.y) chart.options.scales.y.title!.text = 'Milliseconds';
          if (heading) heading.textContent = 'Return latency';
        }
        chart.update();
      });
    });
  }
</script>
