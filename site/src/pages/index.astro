---
import Base from '../layouts/Base.astro';
import { latestStable, loadResults } from '../lib/results';

const routes = await loadResults();
const latest = latestStable(routes);
if (latest) return Astro.redirect(`/${latest.version}/${latest.profile}/${latest.workload}/${latest.variant}/`);
---

<Base title="SlateDB Benchmarks">
  <main class="empty-state">
    <a class="wordmark" href="https://slatedb.io">SlateDB</a>
    <p class="eyebrow">Release benchmarks</p>
    <h1>No published results yet.</h1>
    <p>Validated result files under <code>results/</code> appear here at the next static build.</p>
  </main>
</Base>
