---
import MeasurementRows from '../../../../components/MeasurementRows.astro';
import ResultChart from '../../../../components/ResultChart.astro';
import CostCalculator from '../../../../components/CostCalculator.astro';
import Base from '../../../../layouts/Base.astro';
import { loadPricing, loadResults, routeHref, type BenchmarkResult, type BenchmarkTimeseries } from '../../../../lib/results';

export async function getStaticPaths() {
  const routes = await loadResults();
  return routes.map((route) => ({ params: { version: route.version, suite: route.suite, workload: route.workload, variant: route.variant }, props: { route, routes } }));
}

const { route, routes } = Astro.props;
const result = route.result as BenchmarkResult;
const timeseries = route.timeseries as BenchmarkTimeseries;
const pricing = await loadPricing();
const catalog = routes.map((candidate: typeof route) => ({ version: candidate.version, suite: candidate.suite, workload: candidate.workload, variant: candidate.variant, href: routeHref(candidate) }));
const rawBase = `/raw/${route.version}/${route.suite}/${route.workload}/${route.variant}`;
const configBase = `https://github.com/slatedb/slatedb-benchmark/blob/${result.identity.runner_commit}/config`;
const suiteConfig = `${route.suite}.suite.toml`;
const settingsConfig = `${route.suite}.settings.toml`;

const formatBytes = (value: unknown) => {
  const bytes = Number(value || 0);
  const units = ['B', 'KiB', 'MiB', 'GiB', 'TiB'];
  let amount = bytes;
  let index = 0;
  while (amount >= 1024 && index < units.length - 1) { amount /= 1024; index += 1; }
  return `${amount.toFixed(index === 0 ? 0 : 2)} ${units[index]}`;
};
const datasetSizeBytes = result.configuration.record_count * (result.configuration.key_bytes + result.configuration.value_bytes);
const cacheSummary = [
  ['block', result.configuration.block_cache_bytes],
  ['metadata/index', result.configuration.metadata_cache_bytes],
  ['object store', result.configuration.object_store_cache_bytes],
].map(([name, bytes]) => bytes == null ? `${name} disabled` : `${formatBytes(bytes)} ${name}`);
const durabilityMode = result.durability.final_flush_drain_ns == null
  ? null
  : result.durability.lag ? 'Async' : 'Sync';

const {
  object_store_requests: objectStoreRequests,
  database_size_bytes,
  average_database_size_bytes,
  object_store_errors,
  bytes_read,
  bytes_written,
  ...storage
} = result.storage;
const operationOrder = ['get', 'put', 'list', 'delete', 'head', 'copy', 'create_multipart', 'complete_multipart', 'abort_multipart'];
const orderedRequests = Object.fromEntries(Object.entries(objectStoreRequests).sort(
  ([left], [right]) => operationOrder.indexOf(left) - operationOrder.indexOf(right),
));
const objectStoreOperations = {
  database_size_bytes,
  average_database_size_bytes,
  bytes_read,
  bytes_written,
  object_store_errors,
  ...orderedRequests,
};
const tables = [
  ['Application', result.application], ['Durability', result.durability], ['Resources', result.resources],
  ['Storage', storage], ['Object store operations', objectStoreOperations], ['Object-store baseline', result.object_store_baseline],
] as const;
---

<Base title={`${route.workload} · ${route.variant} · SlateDB ${route.version}`}>
  <header class="site-header">
    <a class="wordmark" href="https://slatedb.io" aria-label="SlateDB home">SlateDB</a>
    <span class="site-name">Benchmarks</span>
    {route.version.includes('mock') && <span class="data-badge">Mock data</span>}
  </header>
  <main class="result-shell" data-catalog={JSON.stringify(catalog)} data-current={JSON.stringify({ version: route.version, suite: route.suite, workload: route.workload, variant: route.variant })}>
    <aside class="result-context" aria-label="Benchmark context">
      <nav class="selector-panel" aria-label="Benchmark selection">
        <div class="selectors">
          <label><span>Version</span><select id="version-select" aria-label="SlateDB version"></select></label>
          <label><span>Suite</span><select id="suite-select"></select></label>
          <label><span>Workload</span><select id="workload-select"></select></label>
          <label><span>Variant</span><select id="variant-select"></select></label>
        </div>
      </nav>

      <dl class="metadata-list">
        <div><dt>Machine</dt><dd>{result.environment.runner_type}</dd></div>
        <div><dt>Object store</dt><dd>{result.environment.object_store} · {result.environment.region}</dd></div>
        <div>
          <dt>Dataset</dt>
          <dd class="dataset-equation">
            <span>{result.configuration.record_count.toLocaleString()} records</span>
            <span>× ({formatBytes(result.configuration.key_bytes)} key + {formatBytes(result.configuration.value_bytes)} value)</span>
            <span>= {formatBytes(datasetSizeBytes)}</span>
          </dd>
        </div>
        <div><dt>Cache</dt><dd><ul class="cache-list">{cacheSummary.map((item) => <li>{item}</li>)}</ul></dd></div>
        {durabilityMode && <div><dt>Durability</dt><dd>{durabilityMode}</dd></div>}
      </dl>

      <div class="context-links">
        <nav aria-label="Suite configuration files">
          <span>Configuration</span>
          <a href={`${configBase}/${suiteConfig}`}>{suiteConfig}<span aria-hidden="true">↗</span></a>
          <a href={`${configBase}/${settingsConfig}`}>{settingsConfig}<span aria-hidden="true">↗</span></a>
        </nav>
        <nav aria-label="Raw benchmark files">
          <span>Raw files</span>
          <a href={`${rawBase}/result.json`}>result.json</a>
          <a href={`${rawBase}/histograms.json`}>histograms.json</a>
          <a href={`${rawBase}/timeseries.json`}>timeseries.json</a>
        </nav>
        <nav aria-label="Benchmark source commits">
          <span>Source</span>
          <a href={`https://github.com/slatedb/slatedb/commit/${result.identity.slate_commit}`}>SlateDB commit<span aria-hidden="true">↗</span></a>
          <a href={`https://github.com/slatedb/slatedb-benchmark/commit/${result.identity.runner_commit}`}>Runner commit<span aria-hidden="true">↗</span></a>
        </nav>
      </div>
    </aside>

    <div class="result-content">
      <ResultChart result={result} timeseries={timeseries} variant={route.variant} rawBase={rawBase} />

      <section class="detail-region" aria-labelledby="detail-title">
        <div class="section-heading"><div><h2 id="detail-title">Measurements</h2></div></div>
        {tables.map(([name, values]) => (
          <div class="metric-group">
            <h3>{name}</h3>
            <div class="table-scroll"><table><tbody>
              {Object.entries(values).map(([key, value]) => (
                <MeasurementRows name={key} value={value} />
              ))}
            </tbody></table></div>
          </div>
        ))}
      </section>

      <CostCalculator result={result} pricing={pricing} />

    </div>
  </main>
</Base>

<script>
  const shell = document.querySelector<HTMLElement>('.result-shell');
  if (shell) {
    const catalog = JSON.parse(shell.dataset.catalog || '[]');
    const current = JSON.parse(shell.dataset.current || '{}');
    const controls = {
      version: document.querySelector<HTMLSelectElement>('#version-select'),
      suite: document.querySelector<HTMLSelectElement>('#suite-select'),
      workload: document.querySelector<HTMLSelectElement>('#workload-select'),
      variant: document.querySelector<HTMLSelectElement>('#variant-select'),
    };
    const unique = (values: string[]) => [...new Set(values)];
    const fill = (select: HTMLSelectElement | null, values: string[], selected: string) => {
      if (!select) return;
      select.replaceChildren(...values.map((value) => Object.assign(document.createElement('option'), { value, textContent: value, selected: value === selected })));
    };
    const render = () => {
      fill(controls.version, unique(catalog.map((item: typeof current) => item.version)), current.version);
      fill(controls.suite, unique(catalog.filter((item: typeof current) => item.version === current.version).map((item: typeof current) => item.suite)), current.suite);
      fill(controls.workload, unique(catalog.filter((item: typeof current) => item.version === current.version && item.suite === current.suite).map((item: typeof current) => item.workload)), current.workload);
      fill(controls.variant, unique(catalog.filter((item: typeof current) => item.version === current.version && item.suite === current.suite && item.workload === current.workload).map((item: typeof current) => item.variant)), current.variant);
    };
    const dimensions = ['version', 'suite', 'workload', 'variant'];
    Object.entries(controls).forEach(([name, select]) => select?.addEventListener('change', () => {
      current[name] = select.value;
      const depth = dimensions.indexOf(name);
      const match = catalog.find((item: typeof current) =>
        dimensions.slice(0, depth + 1).every((key) => item[key] === current[key]),
      ) || catalog[0];
      if (match) window.location.href = match.href;
    }));
    render();
  }
</script>
